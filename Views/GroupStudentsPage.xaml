<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="EducationalPlatform.Views.GroupStudentsPage"
             Title="Студенты группы"
             BackgroundColor="{DynamicResource BackgroundColor}">

    <Grid RowDefinitions="Auto,*">
        <!-- Заголовок -->
        <Border Grid.Row="0"
                BackgroundColor="{DynamicResource PrimaryColor}"
                Padding="20,15"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 0,0,0,20">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Button Grid.Column="0"
                        Text="←"
                        Clicked="OnBackClicked"
                        BackgroundColor="Transparent"
                        TextColor="White"
                        FontSize="20"
                        WidthRequest="40"
                        HeightRequest="40" />
                <Label Grid.Column="1"
                       x:Name="GroupTitleLabel"
                       Text="Студенты группы" 
                       FontSize="20" 
                       FontAttributes="Bold" 
                       TextColor="White" 
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />
                <Button Grid.Column="2"
                        Text="+"
                        Clicked="OnAddStudentClicked"
                        BackgroundColor="White"
                        TextColor="{DynamicResource PrimaryColor}"
                        FontSize="20"
                        WidthRequest="40"
                        HeightRequest="40"
                        CornerRadius="20" />
            </Grid>
        </Border>

        <Grid Grid.Row="1" RowDefinitions="Auto,*">
            <!-- Поиск -->
            <Border Grid.Row="0"
                    BackgroundColor="White"
                    Margin="20,20,20,10"
                    Padding="0"
                    Stroke="#E0E0E0"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 12">
                <Entry x:Name="SearchEntry"
                       Placeholder="🔍 Поиск по имени или email..."
                       BackgroundColor="Transparent"
                       Margin="15,0"
                       FontSize="14"
                       HeightRequest="50"
                       TextChanged="OnSearchTextChanged"/>
            </Border>

            <!-- Список студентов -->
            <CollectionView Grid.Row="1"
                          x:Name="StudentsCollectionView"
                          Margin="20,0,20,20"
                          ItemsSource="{Binding Students}"
                          EmptyView="В группе нет студентов">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,5"
                                BackgroundColor="White"
                                Stroke="#E0E0E0"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 12"
                                Padding="15">
                            <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto,Auto">
                                <!-- Аватар -->
                                <Border Grid.Row="0" Grid.RowSpan="3" Grid.Column="0"
                                        WidthRequest="50"
                                        HeightRequest="50"
                                        Stroke="{DynamicResource PrimaryColor}"
                                        StrokeThickness="1"
                                        StrokeShape="RoundRectangle 25"
                                        BackgroundColor="#F5F5F5"
                                        Margin="0,0,15,0">
                                    <Image Source="{Binding AvatarUrl, Converter={StaticResource AvatarConverter}}"
                                           Aspect="AspectFill"
                                           WidthRequest="46"
                                           HeightRequest="46" />
                                </Border>

                                <!-- Имя -->
                                <Label Grid.Row="0" Grid.Column="1"
                                       Text="{Binding FullName}"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       TextColor="{DynamicResource TextColor}"/>

                                <!-- Email -->
                                <Label Grid.Row="1" Grid.Column="1"
                                       Text="{Binding Email}"
                                       FontSize="13"
                                       TextColor="#666"/>

                                <!-- Дата добавления -->
                                <Label Grid.Row="2" Grid.Column="1"
                                       Text="{Binding EnrollmentDate, StringFormat='Добавлен: dd.MM.yyyy'}"
                                       FontSize="11"
                                       TextColor="Gray"/>

                                <!-- Кнопка удаления -->
                                <Button Grid.Row="0" Grid.Column="2"
                                        Grid.RowSpan="3"
                                        Text="🗑️"
                                        Clicked="OnRemoveStudentClicked"
                                        CommandParameter="{Binding .}"
                                        BackgroundColor="#F44336"
                                        TextColor="White"
                                        WidthRequest="40"
                                        HeightRequest="40"
                                        CornerRadius="20"
                                        FontSize="16"
                                        VerticalOptions="Center"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>
    </Grid>
</ContentPage>