<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:EducationalPlatform.Converters"
             x:Class="EducationalPlatform.Views.AdminLanguagesPage"
             Title="Языки программирования"
             BackgroundColor="{DynamicResource BackgroundColor}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:StatusColorConverter x:Key="StatusToColorConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*">
        <!-- Заголовок -->
        <Border Grid.Row="0"
                BackgroundColor="{DynamicResource PrimaryColor}"
                Padding="20,15"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 0,0,0,20">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Button Grid.Column="0"
                        Text="←"
                        Clicked="OnBackClicked"
                        BackgroundColor="Transparent"
                        TextColor="White"
                        FontSize="20"
                        WidthRequest="40"
                        HeightRequest="40" />
                <Label Grid.Column="1"
                       Text="Языки программирования" 
                       FontSize="20" 
                       FontAttributes="Bold" 
                       TextColor="White" 
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />
                <Button Grid.Column="2"
                        Text="+"
                        Clicked="OnAddLanguageClicked"
                        BackgroundColor="White"
                        TextColor="{DynamicResource PrimaryColor}"
                        FontSize="20"
                        WidthRequest="40"
                        HeightRequest="40"
                        CornerRadius="20" />
            </Grid>
        </Border>

        <Grid Grid.Row="1" RowDefinitions="Auto,Auto,*">
            <!-- Статистика -->
            <Grid Grid.Row="0" ColumnDefinitions="*,*,*" ColumnSpacing="10" Margin="20,20,20,10">
                <Border Grid.Column="0"
                        BackgroundColor="#E3F2FD"
                        Padding="15"
                        StrokeShape="RoundRectangle 10">
                    <VerticalStackLayout>
                        <Label Text="Всего" FontSize="11" TextColor="#1976D2"/>
                        <Label x:Name="TotalLanguagesLabel" Text="0" FontSize="18" FontAttributes="Bold" TextColor="#1976D2"/>
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Column="1"
                        BackgroundColor="#E8F5E8"
                        Padding="15"
                        StrokeShape="RoundRectangle 10">
                    <VerticalStackLayout>
                        <Label Text="Активных" FontSize="11" TextColor="#4CAF50"/>
                        <Label x:Name="ActiveLanguagesLabel" Text="0" FontSize="18" FontAttributes="Bold" TextColor="#4CAF50"/>
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Column="2"
                        BackgroundColor="#FFF3E0"
                        Padding="15"
                        StrokeShape="RoundRectangle 10">
                    <VerticalStackLayout>
                        <Label Text="В курсах" FontSize="11" TextColor="#FF9800"/>
                        <Label x:Name="UsedLanguagesLabel" Text="0" FontSize="18" FontAttributes="Bold" TextColor="#FF9800"/>
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <!-- Поиск -->
            <Border Grid.Row="1"
                    BackgroundColor="White"
                    Margin="20,10,20,10"
                    Padding="0"
                    Stroke="#E0E0E0"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 12">
                <Entry x:Name="SearchEntry"
                       Placeholder="🔍 Поиск по названию языка..."
                       BackgroundColor="Transparent"
                       Margin="15,0"
                       FontSize="14"
                       HeightRequest="50"
                       TextChanged="OnSearchTextChanged"/>
            </Border>

            <!-- Список языков -->
            <CollectionView Grid.Row="2"
                          x:Name="LanguagesCollectionView"
                          Margin="20,0,20,20"
                          ItemsSource="{Binding Languages}"
                          EmptyView="Нет языков программирования">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,5"
                                BackgroundColor="White"
                                Stroke="#00BCD4"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 12"
                                Padding="15">
                            <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto">
                                <!-- Иконка -->
                                <Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="0"
                                        BackgroundColor="#00BCD4"
                                        WidthRequest="50"
                                        HeightRequest="50"
                                        StrokeShape="RoundRectangle 10"
                                        Margin="0,0,15,0">
                                    <Label Text="{Binding Icon, Converter={StaticResource LanguageIconConverter}}"
                                           FontSize="24"
                                           TextColor="White"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"/>
                                </Border>

                                <!-- Название и статус -->
                                <Grid Grid.Row="0" Grid.Column="1" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                    <Label Grid.Column="0"
                                           Text="{Binding LanguageName}"
                                           FontSize="16"
                                           FontAttributes="Bold"
                                           TextColor="#333"/>
                                    <Border Grid.Column="1"
                                            BackgroundColor="{Binding IsActive, Converter={StaticResource StatusToColorConverter}}"
                                            Padding="6,3"
                                            StrokeShape="RoundRectangle 3">
                                        <Label Text="{Binding IsActive, Converter={StaticResource ActiveStatusTextConverter}}"
                                               TextColor="White"
                                               FontSize="9"
                                               FontAttributes="Bold"/>
                                    </Border>
                                </Grid>

                                <!-- Количество курсов -->
                                <Label Grid.Row="1" Grid.Column="1"
                                       Text="{Binding CoursesCount, StringFormat='📚 {0} курсов'}"
                                       FontSize="12"
                                       TextColor="Gray"/>

                                <!-- Кнопки действий -->
                                <HorizontalStackLayout Grid.Row="0" Grid.Column="2"
                                                      Grid.RowSpan="2"
                                                      Spacing="8"
                                                      VerticalOptions="Center">
                                    <Button Text="✏️"
                                            Clicked="OnEditLanguageClicked"
                                            CommandParameter="{Binding .}"
                                            BackgroundColor="#FFC107"
                                            TextColor="White"
                                            WidthRequest="40"
                                            HeightRequest="40"
                                            CornerRadius="20"
                                            FontSize="16"/>
                                    <Button Text="🗑️"
                                            Clicked="OnDeleteLanguageClicked"
                                            CommandParameter="{Binding .}"
                                            BackgroundColor="#F44336"
                                            TextColor="White"
                                            WidthRequest="40"
                                            HeightRequest="40"
                                            CornerRadius="20"
                                            FontSize="16"/>
                                </HorizontalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>
    </Grid>
</ContentPage>