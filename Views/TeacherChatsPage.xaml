<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:EducationalPlatform.Converters"
             x:Class="EducationalPlatform.Views.TeacherChatsPage"
             Title="{Binding Title}"
             BackgroundColor="{DynamicResource BackgroundColor}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:GreaterThanZeroConverter x:Key="GreaterThanZeroConverter" />
            <converters:InverseBoolConverter x:Key="InverseBoolConverter" />
            <converters:NotNullConverter x:Key="NotNullConverter" />
            <converters:AvatarToImageSourceConverter x:Key="AvatarConverter" />
            <converters:MoscowTimeConverter x:Key="MoscowTimeConverter" />
            <converters:ActiveStatusColorConverter x:Key="ActiveStatusColorConverter" />
            <converters:ActiveStatusTextConverter x:Key="ActiveStatusTextConverter" />
            <converters:ColorConverter x:Key="ColorConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*">
        <Grid x:Name="LoadingOverlay"
              Grid.RowSpan="2"
              BackgroundColor="#80000000"
              IsVisible="False">
            <VerticalStackLayout Spacing="20"
                                VerticalOptions="Center"
                                HorizontalOptions="Center">
                <ActivityIndicator x:Name="LoadingIndicator"
                                   IsRunning="False"
                                   Color="White"
                                   HeightRequest="50"
                                   WidthRequest="50"/>
                <Label x:Name="LoadingLabel"
                       Text="Загрузка чатов..."
                       TextColor="White"
                       FontSize="16"/>
            </VerticalStackLayout>
        </Grid>

        <Border Grid.Row="0" 
                BackgroundColor="{DynamicResource PrimaryColor}"
                Padding="20,15"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 0,0,0,20">
            <Grid ColumnDefinitions="*,Auto" VerticalOptions="Center">
                <Label Grid.Column="0" 
                       x:Name="HeaderLabel"
                       Text="👨‍🏫 Чаты групп" 
                       FontSize="22" 
                       FontAttributes="Bold" 
                       TextColor="White" />
                <Button Grid.Column="1" 
                        x:Name="ManageGroupsButton"
                        Text="⚙️ Управление" 
                        Clicked="OnManageGroupsClicked"
                        BackgroundColor="White" 
                        TextColor="{DynamicResource PrimaryColor}" 
                        CornerRadius="20" 
                        Padding="12,6"
                        FontSize="12" />
            </Grid>
        </Border>

        <CollectionView Grid.Row="1"
                        x:Name="GroupsCollectionView"
                        ItemsSource="{Binding Groups}"
                        SelectionMode="Single"
                        SelectionChanged="OnGroupSelected"
                        Margin="10">
            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center" 
                                     VerticalOptions="Center" 
                                     Spacing="20"
                                     Padding="20">
                    <Label Text="👥" 
                           FontSize="64" 
                           HorizontalOptions="Center" 
                           TextColor="#999" />
                    <Label Text="У вас пока нет групп"
                           FontSize="18"
                           TextColor="#999"
                           HorizontalOptions="Center" />
                    <Label Text="Создайте группу в управлении"
                           FontSize="14"
                           TextColor="#999"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Margin="5,8"
                            Padding="15"
                            BackgroundColor="White"
                            Stroke="{DynamicResource PrimaryColor}"
                            StrokeThickness="{Binding HasUnreadMessages, Converter={StaticResource GreaterThanZeroConverter}}"
                            StrokeShape="RoundRectangle 15">
                        <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto,Auto">

                            <Border Grid.Row="0" Grid.RowSpan="3" Grid.Column="0"
                                    WidthRequest="60"
                                    HeightRequest="60"
                                    Stroke="{DynamicResource PrimaryColor}"
                                    StrokeThickness="2"
                                    StrokeShape="RoundRectangle 30"
                                    BackgroundColor="White"
                                    Margin="0,0,15,0">
                                <Image Source="{Binding GroupAvatarUrl, Converter={StaticResource AvatarConverter}}"
                                       Aspect="AspectFill"
                                       WidthRequest="56"
                                       HeightRequest="56" />
                            </Border>

                            <Label Grid.Row="0" Grid.Column="1"
                                   Text="{Binding GroupName}"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   TextColor="{DynamicResource TextColor}"
                                   LineBreakMode="TailTruncation"
                                   VerticalOptions="End" />

                            <Label Grid.Row="0" Grid.Column="2"
                                   Text="{Binding LastMessageTime, Converter={StaticResource MoscowTimeConverter}}"
                                   FontSize="11"
                                   TextColor="Gray"
                                   VerticalOptions="End" />

                            <Label Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"
                                   Text="{Binding CourseName}"
                                   FontSize="13"
                                   TextColor="{DynamicResource PrimaryColor}"
                                   Margin="0,2,0,2" />

                            <Label Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2"
                                   Text="{Binding LastMessage}"
                                   FontSize="13"
                                   TextColor="#666"
                                   MaxLines="2"
                                   LineBreakMode="TailTruncation" />

                            <Border Grid.Row="1" Grid.Column="2"
                                    BackgroundColor="#FF3B30"
                                    Padding="8,4"
                                    VerticalOptions="Start"
                                    IsVisible="{Binding HasUnreadMessages}">
                                <Label Text="{Binding UnreadMessages}"
                                       FontSize="11"
                                       FontAttributes="Bold"
                                       TextColor="White" />
                            </Border>

                            <HorizontalStackLayout Grid.Row="2" Grid.Column="2"
                                                   Spacing="8"
                                                   HorizontalOptions="End"
                                                   VerticalOptions="End">
                                <Label Text="{Binding StudentCount, StringFormat='👥 {0}'}"
                                       FontSize="11"
                                       TextColor="Gray" />
                                <Label Text="{Binding IsActive, Converter={StaticResource ActiveStatusTextConverter}}"
                                       FontSize="11"
                                       TextColor="{Binding IsActive, Converter={StaticResource ActiveStatusColorConverter}}"
                                       FontAttributes="Bold" />
                            </HorizontalStackLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>