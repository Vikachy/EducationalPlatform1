<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:converters="clr-namespace:EducationalPlatform.Converters"
    x:Class="EducationalPlatform.Views.TeacherManagementPage"
    Title="Управление курсами"
    BackgroundColor="{DynamicResource BackgroundColor}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <!-- Конвертеры с разными именами -->
            <converters:BoolToColorConverter x:Key="StatusColorConverter" 
                                 TrueColor="#4CAF50" 
                                 FalseColor="#FF9800"/>
            <converters:BoolToColorConverter x:Key="ButtonColorConverter" 
                                 TrueColor="#FF9800" 
                                 FalseColor="#4CAF50"/>
            <converters:BoolToTextConverter x:Key="PublishedTextConverter" 
                                           TrueText="Опубликован" 
                                           FalseText="Черновик"/>
            <converters:BoolToButtonTextConverter x:Key="PublishButtonTextConverter" 
                                                 TrueText="Снять публикацию" 
                                                 FalseText="Опубликовать"/>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*">
        <!-- Заголовок -->
        <Border Grid.Row="0"
                BackgroundColor="{DynamicResource PrimaryColor}"
                Padding="20,15"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 0,0,0,20">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Button Grid.Column="0"
                        Text="←"
                        Clicked="OnBackClicked"
                        BackgroundColor="Transparent"
                        TextColor="White"
                        FontSize="20"
                        WidthRequest="40"
                        HeightRequest="40" />
                <Label Grid.Column="1"
                       Text="Панель преподавателя" 
                       FontSize="20" 
                       FontAttributes="Bold" 
                       TextColor="White" 
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />
                <Label Grid.Column="2"
                       Text="👨‍🏫"
                       FontSize="20"
                       TextColor="White"
                       VerticalOptions="Center"
                       Margin="0,0,10,0" />
            </Grid>
        </Border>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="20" Padding="20">

                <!-- Быстрый доступ -->
                <Border BackgroundColor="White"
                        Stroke="#E0E0E0"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 12"
                        Padding="15">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="⚡ Быстрый доступ"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="{DynamicResource PrimaryColor}"/>
                        <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="8">
                            <Button Grid.Column="0"
                                    Text="📊 Отчеты"
                                    Clicked="OnReportsClicked"
                                    BackgroundColor="#4A6FA5"
                                    TextColor="White"
                                    HeightRequest="50"
                                    CornerRadius="8"
                                    FontSize="12"/>
                            <Button Grid.Column="1"
                                    Text="👥 Группы"
                                    Clicked="OnGroupsClicked"
                                    BackgroundColor="{DynamicResource SecondaryColor}"
                                    TextColor="White"
                                    HeightRequest="50"
                                    CornerRadius="8"
                                    FontSize="12"/>
                            <Button Grid.Column="2"
                                    Text="📝 Тесты"
                                    Clicked="OnTestsClicked"
                                    BackgroundColor="{DynamicResource AccentColor}"
                                    TextColor="White"
                                    HeightRequest="50"
                                    CornerRadius="8"
                                    FontSize="12"/>
                            <Button Grid.Column="3"
                                    Text="💬 Чаты"
                                    Clicked="OnChatsClicked"
                                    BackgroundColor="#4CAF50"
                                    TextColor="White"
                                    HeightRequest="50"
                                    CornerRadius="8"
                                    FontSize="12"/>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Создание нового курса -->
                <Border BackgroundColor="White"
                        Stroke="{DynamicResource PrimaryColor}"
                        StrokeThickness="2"
                        StrokeShape="RoundRectangle 12"
                        Padding="15">
                    <VerticalStackLayout Spacing="15">
                        <Label Text="➕ Создать новый курс" 
                               FontSize="18" 
                               FontAttributes="Bold"
                               TextColor="{DynamicResource PrimaryColor}" />

                        <Border BackgroundColor="#F8F9FA"
                                Stroke="#E0E0E0"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 8"
                                Padding="0">
                            <Entry x:Name="NewCourseNameEntry" 
                                   Placeholder="Название курса"
                                   BackgroundColor="Transparent"
                                   Margin="15,0"
                                   FontSize="15"
                                   HeightRequest="50" />
                        </Border>

                        <Border BackgroundColor="#F8F9FA"
                                Stroke="#E0E0E0"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 8"
                                Padding="0">
                            <Editor x:Name="NewCourseDescriptionEditor" 
                                    Placeholder="Описание курса" 
                                    HeightRequest="80"
                                    BackgroundColor="Transparent"
                                    Margin="15,10"
                                    FontSize="14" />
                        </Border>

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                            <Border Grid.Column="0"
                                    BackgroundColor="#F8F9FA"
                                    Stroke="#E0E0E0"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 8"
                                    Padding="0">
                                <Picker x:Name="LanguagePicker"
                                        Title="Язык программирования"
                                        ItemDisplayBinding="{Binding LanguageName}"
                                        BackgroundColor="Transparent"
                                        Margin="15,0"
                                        FontSize="14"
                                        HeightRequest="50" />
                            </Border>

                            <Border Grid.Column="1"
                                    BackgroundColor="#F8F9FA"
                                    Stroke="#E0E0E0"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 8"
                                    Padding="0">
                                <Picker x:Name="DifficultyPicker"
                                        Title="Уровень сложности"
                                        ItemDisplayBinding="{Binding DifficultyName}"
                                        BackgroundColor="Transparent"
                                        Margin="15,0"
                                        FontSize="14"
                                        HeightRequest="50" />
                            </Border>
                        </Grid>

                        <HorizontalStackLayout Spacing="10">
                            <CheckBox x:Name="IsGroupCourseCheckBox"/>
                            <Label Text="Для учебных групп" 
                                   VerticalOptions="Center"
                                   FontSize="14"/>
                        </HorizontalStackLayout>

                        <Button x:Name="CreateCourseButton" 
                                Text="Создать курс" 
                                BackgroundColor="{DynamicResource PrimaryColor}" 
                                TextColor="White"
                                CornerRadius="8"
                                HeightRequest="50"
                                FontSize="16"
                                FontAttributes="Bold"
                                Clicked="OnCreateCourseClicked" />
                    </VerticalStackLayout>
                </Border>

                <!-- Мои курсы -->
                <Label Text="📚 Мои курсы" 
                       FontSize="18" 
                       FontAttributes="Bold"
                       TextColor="{DynamicResource PrimaryColor}"
                       Margin="0,5,0,0" />

                <CollectionView x:Name="MyCoursesCollectionView"
                                ItemsSource="{Binding MyCourses}"
                                EmptyView="У вас пока нет курсов">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,5" 
                                    BackgroundColor="White"
                                    Stroke="{DynamicResource PrimaryColor}"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 12"
                                    Padding="15">
                                <VerticalStackLayout Spacing="12">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <Label Text="{Binding CourseName}" 
                                               FontSize="16" 
                                               FontAttributes="Bold"
                                               TextColor="{DynamicResource PrimaryColor}"
                                               LineBreakMode="TailTruncation"/>
                                        <Border Grid.Column="1"
                                                BackgroundColor="{Binding IsPublished, Converter={StaticResource StatusColorConverter}}"
                                                Padding="8,3"
                                                StrokeShape="RoundRectangle 5">
                                            <Label Text="{Binding IsPublished, Converter={StaticResource PublishedTextConverter}}"
                                                   TextColor="White"
                                                   FontSize="10"
                                                   FontAttributes="Bold"/>
                                        </Border>
                                    </Grid>

                                    <Label Text="{Binding Description}" 
                                           FontSize="13" 
                                           TextColor="#666" 
                                           MaxLines="2"
                                           LineBreakMode="TailTruncation" />

                                    <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="5">
                                        <Button Grid.Column="0"
                                                Text="Группы"
                                                BackgroundColor="#4CAF50" 
                                                TextColor="White" 
                                                FontSize="11"
                                                HeightRequest="35"
                                                CornerRadius="6"
                                                Clicked="OnManageGroupsClicked" 
                                                CommandParameter="{Binding .}"/>
                                        <Button Grid.Column="1"
                                                Text="Статистика"
                                                BackgroundColor="#2196F3" 
                                                TextColor="White" 
                                                FontSize="11"
                                                HeightRequest="35"
                                                CornerRadius="6"
                                                Clicked="OnCourseStatsClicked" 
                                                CommandParameter="{Binding CourseId}"/>
                                        <Button Grid.Column="2"
                                                Text="Контент"
                                                BackgroundColor="#FF9800" 
                                                TextColor="White" 
                                                FontSize="11"
                                                HeightRequest="35"
                                                CornerRadius="6"
                                                Clicked="OnManageContentClicked" 
                                                CommandParameter="{Binding .}"/>
                                        <Button Grid.Column="3"
                                                Text="{Binding IsPublished, Converter={StaticResource PublishButtonTextConverter}}"
                                                BackgroundColor="{Binding IsPublished, Converter={StaticResource ButtonColorConverter}}"
                                                TextColor="White" 
                                                FontSize="11"
                                                HeightRequest="35"
                                                CornerRadius="6"
                                                Clicked="OnPublishCourseClicked" 
                                                CommandParameter="{Binding .}"/>
                                    </Grid>
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- Работы на проверку -->
                <Border BackgroundColor="#FFF3E0" 
                        Stroke="#FF9800" 
                        StrokeThickness="2"
                        StrokeShape="RoundRectangle 12"
                        Padding="15">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="📋 Работы на проверку" 
                               FontSize="16" 
                               FontAttributes="Bold"
                               TextColor="#FF9800" />

                        <CollectionView x:Name="PendingReviewsCollectionView" 
                                       ItemsSource="{Binding PendingReviews}"
                                       HeightRequest="200"
                                       EmptyView="Пока нет работ на проверку">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,3" 
                                            BackgroundColor="White"
                                            Stroke="#FF9800"
                                            StrokeThickness="1"
                                            StrokeShape="RoundRectangle 8"
                                            Padding="10">
                                        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                                            <Label Grid.Row="0" Grid.Column="0"
                                                   Text="{Binding StudentName}" 
                                                   FontSize="14" 
                                                   FontAttributes="Bold"
                                                   TextColor="#333"/>
                                            <Label Grid.Row="1" Grid.Column="0"
                                                   Text="{Binding LessonTitle}" 
                                                   FontSize="12" 
                                                   TextColor="#666"
                                                   LineBreakMode="TailTruncation"/>
                                            <Button Grid.Row="0" Grid.Column="1"
                                                    Grid.RowSpan="2"
                                                    Text="Проверить"
                                                    BackgroundColor="#FF9800" 
                                                    TextColor="White" 
                                                    FontSize="11"
                                                    HeightRequest="35"
                                                    WidthRequest="80"
                                                    CornerRadius="6"
                                                    VerticalOptions="Center"
                                                    Clicked="OnReviewWorkClicked" 
                                                    CommandParameter="{Binding .}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>

                <!-- Кнопка назад -->
                <Button Text="Назад" 
                        Clicked="OnBackClicked" 
                        BackgroundColor="Transparent" 
                        TextColor="{DynamicResource PrimaryColor}" 
                        BorderColor="{DynamicResource PrimaryColor}" 
                        BorderWidth="1"
                        HeightRequest="50"
                        CornerRadius="10"
                        Margin="0,10,0,0" />
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>