<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="EducationalPlatform.Views.TheoryStudyPage"
             Title="{Binding TitleLabel.Text}"
             BackgroundColor="{DynamicResource PageBackgroundColor}">

    <Grid RowDefinitions="Auto,*,Auto">
        <!-- Шапка -->
        <Frame Grid.Row="0" 
               BackgroundColor="{DynamicResource PrimaryColor}"
               Padding="16"
               CornerRadius="0"
               HasShadow="True">
            <Grid ColumnDefinitions="*,Auto">
                <Label x:Name="TitleLabel"
                       TextColor="White"
                       FontSize="Title"
                       FontAttributes="Bold"
                       VerticalOptions="Center"/>
                <Button Grid.Column="1"
                        Text="← Назад"
                        Clicked="OnBackClicked"
                        TextColor="White"
                        FontAttributes="Bold"
                        BackgroundColor="Transparent"
                        BorderColor="White"
                        BorderWidth="1"
                        CornerRadius="8"
                        Padding="16,8"/>
            </Grid>
        </Frame>

        <!-- Основной контент -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20" Spacing="20">

                <!-- Индикатор загрузки -->
                <ActivityIndicator x:Name="LoadingIndicator"
                                   IsRunning="False"
                                   Color="{DynamicResource PrimaryColor}"
                                   HorizontalOptions="Center"
                                   HeightRequest="48"/>

                <!-- Текст теории -->
                <Label x:Name="ContentLabel"
                       FontSize="Medium"
                       LineBreakMode="WordWrap"
                       TextColor="{DynamicResource TextColor}"/>

                <!-- Блок вложений -->
                <Frame x:Name="AttachmentsSection"
                       IsVisible="False"
                       BackgroundColor="{DynamicResource CardBackground}"
                       Padding="16"
                       CornerRadius="16"
                       HasShadow="True"
                       BorderColor="{DynamicResource PrimaryColorLight}">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Прикреплённые материалы"
                               FontSize="Large"
                               FontAttributes="Bold"
                               TextColor="{DynamicResource PrimaryColor}"/>

                        <CollectionView x:Name="AttachmentsCollection"
                                        ItemsSource="{Binding Attachments}"
                                        VerticalOptions="FillAndExpand">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Frame BackgroundColor="White"
                                           CornerRadius="12"
                                           Padding="12"
                                           HasShadow="True"
                                           Margin="0,6">
                                        <Frame.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnAttachmentTapped" CommandParameter="{Binding .}"/>
                                        </Frame.GestureRecognizers>

                                        <Grid ColumnDefinitions="60,*,Auto" ColumnSpacing="16">
                                            <!-- Иконка -->
                                            <Frame Grid.Column="0"
                                                   BackgroundColor="{DynamicResource PrimaryColor}"
                                                   WidthRequest="52"
                                                   HeightRequest="52"
                                                   CornerRadius="12"
                                                   VerticalOptions="Center"
                                                   HorizontalOptions="Center">
                                                <Label Text="{Binding FileIcon}"
                                                       FontSize="28"
                                                       TextColor="White"
                                                       HorizontalOptions="Center"
                                                       VerticalOptions="Center"/>
                                            </Frame>

                                            <!-- Информация -->
                                            <VerticalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">
                                                <Label Text="{Binding FileName}"
                                                       FontSize="Medium"
                                                       FontAttributes="Bold"
                                                       MaxLines="2"
                                                       LineBreakMode="TailTruncation"/>
                                                <Label Text="{Binding FileSize}"
                                                       FontSize="Caption"
                                                       TextColor="Gray"/>
                                            </VerticalStackLayout>

                                            <!-- Кнопка скачать -->
                                            <Button Grid.Column="2"
                                                    Text="↓"
                                                    FontSize="24"
                                                    WidthRequest="52"
                                                    HeightRequest="52"
                                                    CornerRadius="26"
                                                    BackgroundColor="{DynamicResource AccentColor}"
                                                    TextColor="White"
                                                    Clicked="OnOpenAttachmentClicked"
                                                    CommandParameter="{Binding .}"
                                                    VerticalOptions="Center"/>
                                        </Grid>
                                    </Frame>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Frame>
            </VerticalStackLayout>
        </ScrollView>

        <!-- Нижняя панель навигации -->
        <HorizontalStackLayout Grid.Row="2"
                               Padding="16"
                               Spacing="12"
                               BackgroundColor="{DynamicResource CardBackground}"
                               VerticalOptions="End">
            <Button x:Name="PrevButton"
                    Text="⬅ Предыдущий урок"
                    Clicked="OnPrevClicked"
                    IsVisible="False"
                    Style="{DynamicResource OutlineButtonStyle}"
                    HorizontalOptions="FillAndExpand"/>
            <Button x:Name="NextButton"
                    Text="Следующий урок ➜"
                    Clicked="OnNextClicked"
                    Style="{DynamicResource PrimaryButtonStyle}"
                    HorizontalOptions="FillAndExpand"/>
        </HorizontalStackLayout>
    </Grid>
</ContentPage>