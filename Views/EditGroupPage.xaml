<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:EducationalPlatform.Converters"
             x:Class="EducationalPlatform.Views.EditGroupPage"
             Title="Редактирование группы"
             BackgroundColor="{DynamicResource BackgroundColor}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:AvatarToImageSourceConverter x:Key="AvatarConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*">
        <!-- Заголовок -->
        <Border Grid.Row="0"
                BackgroundColor="{DynamicResource PrimaryColor}"
                Padding="20,15"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 0,0,0,20">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Button Grid.Column="0"
                        Text="←"
                        Clicked="OnBackClicked"
                        BackgroundColor="Transparent"
                        TextColor="White"
                        FontSize="20"
                        WidthRequest="40"
                        HeightRequest="40" />
                <Label Grid.Column="1"
                       x:Name="TitleLabel"
                       Text="Редактирование группы" 
                       FontSize="20" 
                       FontAttributes="Bold" 
                       TextColor="White" 
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />
                <Button Grid.Column="2"
                        Text="💾"
                        Clicked="OnSaveClicked"
                        BackgroundColor="White"
                        TextColor="{DynamicResource PrimaryColor}"
                        FontSize="20"
                        WidthRequest="40"
                        HeightRequest="40"
                        CornerRadius="20" />
            </Grid>
        </Border>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20" Spacing="20">

                <!-- Аватар группы -->
                <Border BackgroundColor="White"
                        Stroke="{DynamicResource PrimaryColor}"
                        StrokeThickness="2"
                        StrokeShape="RoundRectangle 12"
                        Padding="20">
                    <VerticalStackLayout Spacing="15" HorizontalOptions="Center">
                        <Border WidthRequest="100"
                                HeightRequest="100"
                                Stroke="{DynamicResource PrimaryColor}"
                                StrokeThickness="2"
                                StrokeShape="RoundRectangle 50"
                                BackgroundColor="#F5F5F5">
                            <Image x:Name="AvatarImage"
                                   Source="{Binding AvatarUrl, Converter={StaticResource AvatarConverter}}"
                                   Aspect="AspectFill"
                                   WidthRequest="96"
                                   HeightRequest="96" />
                        </Border>

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                            <Button Grid.Column="0"
                                    Text="Выбрать"
                                    Clicked="OnSelectAvatarClicked"
                                    BackgroundColor="{DynamicResource SecondaryColor}"
                                    TextColor="White"
                                    HeightRequest="40"
                                    CornerRadius="8"
                                    FontSize="13"/>
                            <Button Grid.Column="1"
                                    Text="Удалить"
                                    Clicked="OnRemoveAvatarClicked"
                                    BackgroundColor="#F44336"
                                    TextColor="White"
                                    HeightRequest="40"
                                    CornerRadius="8"
                                    FontSize="13"/>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Основная информация -->
                <Border BackgroundColor="White"
                        Stroke="{DynamicResource PrimaryColor}"
                        StrokeThickness="2"
                        StrokeShape="RoundRectangle 12"
                        Padding="20">
                    <VerticalStackLayout Spacing="15">
                        <Label Text="Основная информация"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="{DynamicResource PrimaryColor}"/>

                        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="15" ColumnSpacing="15">
                            <!-- Название группы -->
                            <Label Grid.Row="0" Grid.Column="0"
                                   Text="Название:"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="#666"
                                   VerticalOptions="Center"/>
                            <Border Grid.Row="0" Grid.Column="1"
                                    BackgroundColor="#F8F9FA"
                                    Stroke="#E0E0E0"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 8"
                                    Padding="0">
                                <Entry x:Name="GroupNameEntry"
                                       Placeholder="Введите название группы"
                                       BackgroundColor="Transparent"
                                       Margin="15,0"
                                       FontSize="14"
                                       HeightRequest="45"/>
                            </Border>

                            <!-- Курс -->
                            <Label Grid.Row="1" Grid.Column="0"
                                   Text="Курс:"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="#666"
                                   VerticalOptions="Center"/>
                            <Border Grid.Row="1" Grid.Column="1"
                                    BackgroundColor="#F8F9FA"
                                    Stroke="#E0E0E0"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 8"
                                    Padding="0">
                                <Picker x:Name="CoursePicker"
                                        Title="Выберите курс"
                                        BackgroundColor="Transparent"
                                        Margin="15,0"
                                        FontSize="14"
                                        HeightRequest="45"
                                        ItemDisplayBinding="{Binding CourseName}"/>
                            </Border>

                            <!-- Преподаватель -->
                            <Label Grid.Row="2" Grid.Column="0"
                                   Text="Преподаватель:"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="#666"
                                   VerticalOptions="Center"/>
                            <Border Grid.Row="2" Grid.Column="1"
                                    BackgroundColor="#F8F9FA"
                                    Stroke="#E0E0E0"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 8"
                                    Padding="0">
                                <Picker x:Name="TeacherPicker"
                                        Title="Выберите преподавателя"
                                        BackgroundColor="Transparent"
                                        Margin="15,0"
                                        FontSize="14"
                                        HeightRequest="45"
                                        ItemDisplayBinding="{Binding FullName}"/>
                            </Border>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Даты -->
                <Border BackgroundColor="White"
                        Stroke="#FF9800"
                        StrokeThickness="2"
                        StrokeShape="RoundRectangle 12"
                        Padding="20">
                    <VerticalStackLayout Spacing="15">
                        <Label Text="Период обучения"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="#FF9800"/>

                        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto" RowSpacing="15" ColumnSpacing="15">
                            <!-- Дата начала -->
                            <Label Grid.Row="0" Grid.Column="0"
                                   Text="Начало:"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="#666"
                                   VerticalOptions="Center"/>
                            <DatePicker Grid.Row="0" Grid.Column="1"
                                        x:Name="StartDatePicker"
                                        MinimumDate="2024-01-01"
                                        MaximumDate="2026-12-31"/>

                            <!-- Дата окончания -->
                            <Label Grid.Row="1" Grid.Column="0"
                                   Text="Окончание:"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="#666"
                                   VerticalOptions="Center"/>
                            <DatePicker Grid.Row="1" Grid.Column="1"
                                        x:Name="EndDatePicker"
                                        MinimumDate="2024-01-01"
                                        MaximumDate="2026-12-31"/>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Статус -->
                <Border BackgroundColor="White"
                        Stroke="#4CAF50"
                        StrokeThickness="2"
                        StrokeShape="RoundRectangle 12"
                        Padding="20">
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="15">
                        <Label Grid.Column="0"
                               Text="Активна:"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="#666"
                               VerticalOptions="Center"/>
                        <Switch Grid.Column="1"
                                x:Name="IsActiveSwitch"
                                IsToggled="True"
                                OnColor="#4CAF50"
                                ThumbColor="White"
                                VerticalOptions="Center"/>
                    </Grid>
                </Border>

                <!-- Кнопки -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="15">
                    <Button Grid.Column="0"
                            Text="Отмена"
                            Clicked="OnBackClicked"
                            BackgroundColor="#6C757D"
                            TextColor="White"
                            HeightRequest="45"
                            CornerRadius="8"
                            FontSize="14"/>
                    <Button Grid.Column="1"
                            Text="Сохранить"
                            Clicked="OnSaveClicked"
                            BackgroundColor="{DynamicResource SuccessColor}"
                            TextColor="White"
                            HeightRequest="45"
                            CornerRadius="8"
                            FontSize="14"
                            FontAttributes="Bold"/>
                </Grid>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>