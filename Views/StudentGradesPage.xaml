<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:EducationalPlatform.Converters"
             x:Class="EducationalPlatform.Views.StudentGradesPage"
             Title="Мои оценки"
             BackgroundColor="{DynamicResource BackgroundColor}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:ScoreToColorConverter x:Key="ScoreToColorConverter"/>
            <converters:NotNullConverter x:Key="NotNullConverter"/>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*">
        <!-- Заголовок -->
        <Border Grid.Row="0"
                BackgroundColor="{DynamicResource PrimaryColor}"
                Padding="20,15"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 0,0,0,20">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Button Grid.Column="0"
                        Text="←"
                        Clicked="OnBackClicked"
                        BackgroundColor="Transparent"
                        TextColor="White"
                        FontSize="20"
                        WidthRequest="40"
                        HeightRequest="40" />
                <Label Grid.Column="1"
                       Text="Мои оценки" 
                       FontSize="20" 
                       FontAttributes="Bold" 
                       TextColor="White" 
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />
                <Label Grid.Column="2"
                       Text="📊"
                       FontSize="20"
                       TextColor="White"
                       VerticalOptions="Center"
                       Margin="0,0,10,0" />
            </Grid>
        </Border>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20" Spacing="15">

                <!-- Сводка -->
                <Border BackgroundColor="White"
                        Stroke="{DynamicResource SuccessColor}"
                        StrokeThickness="2"
                        StrokeShape="RoundRectangle 12"
                        Padding="20">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="📈 Средний балл" 
                               FontSize="16" 
                               FontAttributes="Bold"
                               TextColor="{DynamicResource SuccessColor}"
                               HorizontalOptions="Center"/>
                        <Label x:Name="AverageScoreLabel" 
                               Text="0"
                               FontSize="36"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"
                               TextColor="{DynamicResource SuccessColor}"/>
                        <Label Text="из 100"
                               FontSize="14"
                               HorizontalOptions="Center"
                               TextColor="Gray"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Список оценок -->
                <Label Text="📋 История оценок"
                       FontSize="18"
                       FontAttributes="Bold"
                       TextColor="{DynamicResource PrimaryColor}"
                       Margin="0,10,0,5"/>

                <CollectionView x:Name="GradesCollection"
                                ItemsSource="{Binding GradedWorks}"
                                EmptyView="У вас пока нет оценок">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,5"
                                    BackgroundColor="White"
                                    Stroke="#E0E0E0"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 12"
                                    Padding="15">
                                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="5">
                                    <Label Grid.Row="0" Grid.Column="0"
                                           Text="{Binding CourseName}"
                                           FontSize="14"
                                           FontAttributes="Bold"
                                           TextColor="{DynamicResource PrimaryColor}"/>
                                    <Label Grid.Row="0" Grid.Column="1"
                                           Text="{Binding ScoreDisplay}"
                                           FontSize="18"
                                           FontAttributes="Bold"
                                           TextColor="{Binding TeacherScore, Converter={StaticResource ScoreToColorConverter}}"/>

                                    <Label Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                           Text="{Binding LessonTitle}"
                                           FontSize="13"
                                           TextColor="#333"/>

                                    <Label Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                           Text="{Binding TeacherComment}"
                                           FontSize="12"
                                           TextColor="Gray"
                                           IsVisible="{Binding TeacherComment, Converter={StaticResource NotNullConverter}}"/>

                                    <Label Grid.Row="3" Grid.Column="0"
                                           Text="{Binding FormattedDate}"
                                           FontSize="11"
                                           TextColor="Gray"/>
                                    <Label Grid.Row="3" Grid.Column="1"
                                           Text="{Binding TeacherName}"
                                           FontSize="11"
                                           TextColor="Gray"
                                           HorizontalOptions="End"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>