<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:EducationalPlatform.Converters"
             xmlns:models="clr-namespace:EducationalPlatform.Models"
             x:Class="EducationalPlatform.Views.ChatPage"
             Title="{Binding ChatTitle}"
             BackgroundColor="{DynamicResource BackgroundColor}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:InverseBoolConverter x:Key="InverseBoolConverter" />
            <converters:FileTypeToIconConverter x:Key="FileTypeToIconConverter" />
            <converters:NotNullConverter x:Key="NotNullConverter" />
            <converters:AvatarToImageSourceConverter x:Key="AvatarConverter" />
            <converters:MessageStatusColorConverter x:Key="MessageStatusColorConverter" />
            <converters:OnlineStatusColorConverter x:Key="OnlineStatusColor" />
            <converters:GreaterThanZeroConverter x:Key="GreaterThanZeroConverter" />
            <converters:MoscowTimeConverter x:Key="MoscowTimeConverter" />
            <converters:ColorConverter x:Key="ColorConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Индикатор загрузки на весь экран -->
        <Grid x:Name="LoadingOverlay"
              Grid.RowSpan="3"
              BackgroundColor="#80000000"
              IsVisible="False">
            <VerticalStackLayout Spacing="20"
                                VerticalOptions="Center"
                                HorizontalOptions="Center">
                <ActivityIndicator x:Name="LoadingIndicator"
                                   IsRunning="False"
                                   Color="White"
                                   HeightRequest="50"
                                   WidthRequest="50"/>
                <Label x:Name="LoadingLabel"
                       Text="Загрузка сообщений..."
                       TextColor="White"
                       FontSize="16"/>
            </VerticalStackLayout>
        </Grid>

        <!-- Header как в Telegram -->
        <Border Grid.Row="0" 
                BackgroundColor="{DynamicResource PrimaryColor}"
                StrokeThickness="0"
                Padding="10">
            <Grid ColumnDefinitions="Auto,*,Auto,Auto" 
                  VerticalOptions="Center"
                  HeightRequest="60">

                <!-- Кнопка назад -->
                <Button Grid.Column="0" 
                        Text="←" 
                        Clicked="OnBackClicked"
                        BackgroundColor="Transparent"
                        TextColor="White"
                        FontSize="20"
                        WidthRequest="44"
                        HeightRequest="44"/>

                <!-- Информация о пользователе -->
                <HorizontalStackLayout Grid.Column="1" 
                                      Spacing="10"
                                      HorizontalOptions="Start"
                                      VerticalOptions="Center">

                    <!-- Аватар с рамкой - ИСПРАВЛЕНО: добавлен ColorConverter -->
                    <Border x:Name="AvatarFrameBorder"
                            WidthRequest="44"
                            HeightRequest="44"
                            Stroke="{Binding FrameColor, Converter={StaticResource ColorConverter}}"
                            StrokeThickness="2"
                            StrokeShape="RoundRectangle 22"
                            BackgroundColor="White">
                        <Image Source="{Binding AvatarUrl, Converter={StaticResource AvatarConverter}}" />

                    </Border>

                    <!-- Имя и статус -->
                    <VerticalStackLayout Spacing="2"
                                       VerticalOptions="Center">
                        <HorizontalStackLayout Spacing="4">
                            <Label x:Name="ChatNameLabel"
                                   Text="{Binding ChatName}"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   TextColor="White"
                                   LineBreakMode="TailTruncation" />
                            <Label x:Name="UserEmojiLabel"
                                   Text="{Binding UserEmoji}"
                                   FontSize="16"
                                   TextColor="White"
                                   IsVisible="{Binding UserEmoji, Converter={StaticResource NotNullConverter}}" />
                        </HorizontalStackLayout>
                        <Label x:Name="OnlineStatusLabel"
                               Text="{Binding OnlineStatus}"
                               FontSize="11"
                               TextColor="LightGray" />
                    </VerticalStackLayout>
                </HorizontalStackLayout>

                <!-- Кнопки действий -->
                <Button Grid.Column="2" 
                        Text="🔍"
                        Clicked="OnSearchClicked"
                        BackgroundColor="Transparent"
                        TextColor="White"
                        FontSize="18"
                        WidthRequest="44"
                        HeightRequest="44"/>

                <Button Grid.Column="3" 
                        Text="⋮"
                        Clicked="OnMenuClicked"
                        BackgroundColor="Transparent"
                        TextColor="White"
                        FontSize="20"
                        WidthRequest="44"
                        HeightRequest="44"/>
            </Grid>
        </Border>

        <!-- Messages Area -->
        <Grid Grid.Row="1">
            <ActivityIndicator x:Name="LoadingIndicator2"
                              IsVisible="False"
                              IsRunning="False"
                              Color="{DynamicResource PrimaryColor}"
                              VerticalOptions="Center"
                              HorizontalOptions="Center" />

            <ScrollView x:Name="MessagesScrollView"
                       Scrolled="OnMessagesScrolled">
                <VerticalStackLayout>
                    <CollectionView x:Name="MessagesCollectionView"
                                    ItemsSource="{Binding GroupedMessages}"
                                    SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:GroupedPrivateMessages">
                                <VerticalStackLayout>
                                    <!-- Date Header - ИСПРАВЛЕНО: используется MoscowTimeConverter -->
                                    <Border HorizontalOptions="Center"
                                            BackgroundColor="#E0E0E0"
                                            Padding="10,5"
                                            Margin="0,10"
                                            StrokeShape="RoundRectangle 15">
                                        <Label Text="{Binding Date}"
                                               FontSize="11"
                                               TextColor="#666"
                                               FontAttributes="Bold" />
                                    </Border>

                                    <!-- Messages for this date -->
                                    <CollectionView ItemsSource="{Binding Messages}"
                                                    SelectionMode="None">
                                        <CollectionView.ItemTemplate>
                                            <DataTemplate x:DataType="models:PrivateChatMessage">
                                                <Grid Padding="10,5"
                                                      ColumnDefinitions="Auto,*,Auto"
                                                      BackgroundColor="{Binding BackgroundColor}">

                                                    <!-- Other user's message -->
                                                    <Frame Grid.Column="0"
                                                           Grid.ColumnSpan="2"
                                                           IsVisible="{Binding IsMyMessage, Converter={StaticResource InverseBoolConverter}}"
                                                           BackgroundColor="#FFFFFF"
                                                           Padding="12"
                                                           HorizontalOptions="Start"
                                                           MaximumWidthRequest="{OnPlatform WinUI=400, Default=280}"
                                                           HasShadow="False"
                                                           CornerRadius="18"
                                                           BorderColor="#E0E0E0">
                                                        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto" 
                                                              ColumnSpacing="8" RowSpacing="2">

                                                            <!-- Avatar with frame - ИСПРАВЛЕНО: добавлен ColorConverter -->
                                                            <Border Grid.Row="0" Grid.RowSpan="3" Grid.Column="0"
                                                                    BackgroundColor="White"
                                                                    Stroke="{Binding SenderFrameColor, Converter={StaticResource ColorConverter}}"
                                                                    StrokeThickness="2"
                                                                    StrokeShape="RoundRectangle 20"
                                                                    WidthRequest="40"
                                                                    HeightRequest="40"
                                                                    VerticalOptions="Start">
                                                                <Image Source="{Binding AvatarUrl, Converter={StaticResource AvatarConverter}}" 
                                                                Aspect="AspectFill"
                                                                       WidthRequest="36"
                                                                       HeightRequest="36" />
                                                            </Border>

                                                            <!-- Sender Name with Emoji -->
                                                            <HorizontalStackLayout Grid.Row="0" Grid.Column="1"
                                                                                   Spacing="4"
                                                                                   VerticalOptions="End">
                                                                <Label Text="{Binding SenderName}"
                                                                       FontSize="12"
                                                                       TextColor="#2E86AB"
                                                                       FontAttributes="Bold" />
                                                                <Label Text="{Binding UserEmoji}"
                                                                       FontSize="14"
                                                                       IsVisible="{Binding UserEmoji, Converter={StaticResource NotNullConverter}}"
                                                                       VerticalOptions="Center" />
                                                            </HorizontalStackLayout>

                                                            <!-- Message Content -->
                                                            <VerticalStackLayout Grid.Row="1" Grid.Column="1" Spacing="2">
                                                                <!-- Text Message -->
                                                                <Label Text="{Binding MessageText}"
                                                                       TextColor="#000000"
                                                                       FontSize="14"
                                                                       LineBreakMode="WordWrap"
                                                                       IsVisible="{Binding IsFileMessage, Converter={StaticResource InverseBoolConverter}}" />

                                                                <!-- File Message -->
                                                                <Border BackgroundColor="#E8F4F8"
                                                                        Stroke="#2E86AB"
                                                                        StrokeThickness="1"
                                                                        StrokeShape="RoundRectangle 8"
                                                                        Padding="10"
                                                                        IsVisible="{Binding IsFileMessage}">
                                                                    <Border.GestureRecognizers>
                                                                        <TapGestureRecognizer Tapped="OnFileMessageTapped" 
                                                                                             CommandParameter="{Binding .}" />
                                                                    </Border.GestureRecognizers>
                                                                    <Grid ColumnDefinitions="Auto,*" 
                                                                          ColumnSpacing="8">
                                                                        <Label Grid.Column="0"
                                                                               Text="{Binding FileType, Converter={StaticResource FileTypeToIconConverter}}"
                                                                               FontSize="20"
                                                                               VerticalOptions="Center" />
                                                                        <VerticalStackLayout Grid.Column="1">
                                                                            <Label Text="{Binding FileName}"
                                                                                   FontSize="13"
                                                                                   FontAttributes="Bold"
                                                                                   LineBreakMode="TailTruncation"
                                                                                   TextColor="#2E86AB" />
                                                                            <Label Text="{Binding FileSize}"
                                                                                   FontSize="11"
                                                                                   TextColor="Gray" />
                                                                        </VerticalStackLayout>
                                                                    </Grid>
                                                                </Border>
                                                            </VerticalStackLayout>

                                                            <!-- Time - ИСПРАВЛЕНО: используется MoscowTimeConverter -->
                                                            <HorizontalStackLayout Grid.Row="2" Grid.Column="1"
                                                                                  HorizontalOptions="End"
                                                                                  Spacing="4"
                                                                                  VerticalOptions="End">
                                                                <Label Text="{Binding SentAt, Converter={StaticResource MoscowTimeConverter}}"
                                                                       FontSize="10"
                                                                       TextColor="Gray" />
                                                            </HorizontalStackLayout>
                                                        </Grid>
                                                    </Frame>

                                                    <!-- My message -->
                                                    <Frame Grid.Column="1"
                                                           Grid.ColumnSpan="2"
                                                           IsVisible="{Binding IsMyMessage}"
                                                           BackgroundColor="#DCF8C6"
                                                           Padding="12"
                                                           HorizontalOptions="End"
                                                           MaximumWidthRequest="{OnPlatform WinUI=400, Default=280}"
                                                           HasShadow="False"
                                                           CornerRadius="18">
                                                        <Grid RowDefinitions="Auto,Auto" 
                                                              ColumnDefinitions="*,Auto"
                                                              RowSpacing="4">

                                                            <!-- Message Content -->
                                                            <VerticalStackLayout Grid.Row="0" Grid.Column="0" Spacing="2">
                                                                <!-- Text Message -->
                                                                <Label Text="{Binding MessageText}"
                                                                       TextColor="#000000"
                                                                       FontSize="14"
                                                                       LineBreakMode="WordWrap"
                                                                       IsVisible="{Binding IsFileMessage, Converter={StaticResource InverseBoolConverter}}" />

                                                                <!-- File Message -->
                                                                <Border BackgroundColor="#E8F4F8"
                                                                        Stroke="#2E86AB"
                                                                        StrokeThickness="1"
                                                                        StrokeShape="RoundRectangle 8"
                                                                        Padding="10"
                                                                        IsVisible="{Binding IsFileMessage}">
                                                                    <Border.GestureRecognizers>
                                                                        <TapGestureRecognizer Tapped="OnFileMessageTapped" 
                                                                                             CommandParameter="{Binding .}" />
                                                                    </Border.GestureRecognizers>
                                                                    <Grid ColumnDefinitions="Auto,*" 
                                                                          ColumnSpacing="8">
                                                                        <Label Grid.Column="0"
                                                                               Text="{Binding FileType, Converter={StaticResource FileTypeToIconConverter}}"
                                                                               FontSize="20"
                                                                               VerticalOptions="Center" />
                                                                        <VerticalStackLayout Grid.Column="1">
                                                                            <Label Text="{Binding FileName}"
                                                                                   FontSize="13"
                                                                                   FontAttributes="Bold"
                                                                                   LineBreakMode="TailTruncation"
                                                                                   TextColor="#2E86AB" />
                                                                            <Label Text="{Binding FileSize}"
                                                                                   FontSize="11"
                                                                                   TextColor="#666666" />
                                                                        </VerticalStackLayout>
                                                                    </Grid>
                                                                </Border>
                                                            </VerticalStackLayout>

                                                            <!-- Time and Status - ИСПРАВЛЕНО: используется MoscowTimeConverter -->
                                                            <HorizontalStackLayout Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                                                                  HorizontalOptions="End"
                                                                                  Spacing="4"
                                                                                  VerticalOptions="End">
                                                                <Label Text="{Binding SentAt, Converter={StaticResource MoscowTimeConverter}}"
                                                                       FontSize="10"
                                                                       TextColor="#666666" />
                                                                <Label Text="{Binding MessageStatus}"
                                                                       FontSize="10"
                                                                       TextColor="{Binding StatusColor}"
                                                                       FontAttributes="Bold" />
                                                            </HorizontalStackLayout>
                                                        </Grid>
                                                    </Frame>
                                                </Grid>
                                            </DataTemplate>
                                        </CollectionView.ItemTemplate>
                                    </CollectionView>
                                </VerticalStackLayout>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </ScrollView>

            <!-- Scroll to bottom button -->
            <Border x:Name="ScrollToBottomButton"
                    BackgroundColor="{DynamicResource PrimaryColor}"
                    WidthRequest="44"
                    HeightRequest="44"
                    StrokeShape="RoundRectangle 22"
                    HorizontalOptions="End"
                    VerticalOptions="End"
                    Margin="0,0,20,20"
                    IsVisible="False">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnScrollToBottomClicked" />
                </Border.GestureRecognizers>
                <Label Text="⬇️"
                       FontSize="20"
                       TextColor="White"
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />
            </Border>
        </Grid>

        <!-- Typing indicator -->
        <Border x:Name="TypingIndicator"
                Grid.Row="2"
                BackgroundColor="#F0F0F0"
                Padding="10,5"
                IsVisible="False">
            <HorizontalStackLayout Spacing="5">
                <Label Text="✏️"
                       FontSize="14" />
                <Label x:Name="TypingLabel"
                       Text="Печатает..."
                       FontSize="12"
                       TextColor="Gray" />
            </HorizontalStackLayout>
        </Border>

        <Border Grid.Row="2"
                BackgroundColor="White"
                Stroke="#E0E0E0"
                StrokeThickness="1"
                Padding="10">
            <Grid ColumnDefinitions="Auto,*,Auto,Auto" 
                  ColumnSpacing="8"
                  VerticalOptions="Center">

                <!-- Attach button -->
                <Button Grid.Column="0"
                        Text="➕"
                        Clicked="OnAttachMenuClicked"
                        BackgroundColor="Transparent"
                        TextColor="{DynamicResource PrimaryColor}"
                        MinimumWidthRequest="44"
                        MinimumHeightRequest="44"
                        WidthRequest="44"
                        HeightRequest="44"
                        FontSize="18" />

                <Frame Grid.Column="1"
                       BackgroundColor="#F1F1F1"
                       Padding="0"
                       HasShadow="False"
                       HeightRequest="44">
                    <Entry x:Name="MessageEntry"
                           Placeholder="Сообщение..."
                           TextChanged="OnMessageTextChanged"
                           Completed="OnMessageSent"
                           BackgroundColor="Transparent"
                           Margin="15,0"
                           FontSize="14"
                           HorizontalOptions="Fill"
                           VerticalOptions="Center" />
                </Frame>

                <!-- Emoji button -->
                <Button Grid.Column="2"
                        Text="😊"
                        Clicked="OnEmojiClicked"
                        BackgroundColor="Transparent"
                        TextColor="{DynamicResource PrimaryColor}"
                        MinimumWidthRequest="44"
                        MinimumHeightRequest="44"
                        WidthRequest="44"
                        HeightRequest="44"
                        FontSize="18" />

                <!-- Send button - ИСПРАВЛЕНО: добавлен StrokeShape -->
                <Button Grid.Column="3"
                        Text="➤"
                        Clicked="OnSendMessageClicked"
                        BackgroundColor="{DynamicResource PrimaryColor}"
                        TextColor="White"
                        MinimumWidthRequest="44"
                        MinimumHeightRequest="44"
                        WidthRequest="44"
                        HeightRequest="44"
                        FontSize="16"
                        FontAttributes="Bold" />
            </Grid>
        </Border>
    </Grid>
</ContentPage>