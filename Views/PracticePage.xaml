<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:EducationalPlatform.Converters"
             x:Class="EducationalPlatform.Views.PracticePage"
             Title="{Binding PageTitle}"
             BackgroundColor="{DynamicResource BackgroundColor}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:FileTypeToIconConverter x:Key="FileTypeToIconConverter" />
            <converters:InverseBoolConverter x:Key="InverseBoolConverter" />
            <converters:NotNullConverter x:Key="NotNullConverter" />
            <converters:GreaterThanZeroConverter x:Key="GreaterThanZeroConverter" />
            <converters:ScoreToColorConverter x:Key="ScoreToColorConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*">
        <!-- Индикатор загрузки -->
        <Grid x:Name="LoadingOverlay"
              Grid.RowSpan="2"
              BackgroundColor="#80000000"
              IsVisible="False"
              InputTransparent="True">
            <VerticalStackLayout Spacing="20"
                                VerticalOptions="Center"
                                HorizontalOptions="Center">
                <ActivityIndicator x:Name="LoadingIndicator"
                                   IsRunning="False"
                                   Color="White"
                                   HeightRequest="50"
                                   WidthRequest="50"/>
                <Label x:Name="LoadingLabel"
                       Text="Загрузка..."
                       TextColor="White"
                       FontSize="16"/>
            </VerticalStackLayout>
        </Grid>

        <!-- Современная шапка -->
        <Border Grid.Row="0"
                BackgroundColor="{DynamicResource PrimaryColor}"
                Padding="20,15"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 0,0,0,20">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Button Grid.Column="0"
                        Text="←"
                        Clicked="OnBackClicked"
                        BackgroundColor="Transparent"
                        TextColor="White"
                        FontSize="20"
                        WidthRequest="40"
                        HeightRequest="40" />
                <Label Grid.Column="1"
                       x:Name="TitleLabel"
                       Text="Практическое задание"
                       FontSize="20" 
                       FontAttributes="Bold" 
                       TextColor="White" 
                       HorizontalOptions="Center"
                       VerticalOptions="Center"
                       LineBreakMode="TailTruncation"/>
                <Label Grid.Column="2"
                       Text="✏️"
                       FontSize="20"
                       TextColor="White"
                       VerticalOptions="Center"
                       Margin="0,0,10,0" />
            </Grid>
        </Border>

        <!-- Основной контент -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="20" Padding="20">

                <!-- Карточка с заданием -->
                <Border BackgroundColor="White"
                        Stroke="{DynamicResource PrimaryColor}"
                        StrokeThickness="2"
                        StrokeShape="RoundRectangle 12"
                        Padding="20">
                    <VerticalStackLayout Spacing="15">
                        <HorizontalStackLayout Spacing="10">
                            <Label Text="📋"
                                   FontSize="28"
                                   VerticalOptions="Center"/>
                            <Label Text="Задание"
                                   FontSize="22"
                                   FontAttributes="Bold"
                                   TextColor="{DynamicResource PrimaryColor}"
                                   VerticalOptions="Center"/>
                        </HorizontalStackLayout>

                        <!-- Описание задания с красивым оформлением -->
                        <Border BackgroundColor="#F8F9FA"
                                Padding="15"
                                Stroke="#E0E0E0"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 8">
                            <Label x:Name="DescriptionLabel"
                                   FontSize="16"
                                   TextColor="#333"
                                   LineBreakMode="WordWrap" />
                        </Border>
                    </VerticalStackLayout>
                </Border>

                <!-- Стартовый код (если есть) -->
                <Border x:Name="CodeSection"
                       IsVisible="False"
                       BackgroundColor="White"
                       Stroke="{DynamicResource AccentColor}"
                       StrokeThickness="2"
                       StrokeShape="RoundRectangle 12"
                       Padding="20">
                    <VerticalStackLayout Spacing="15">
                        <HorizontalStackLayout Spacing="10">
                            <Label Text="💻"
                                   FontSize="28"
                                   VerticalOptions="Center"/>
                            <Label Text="Стартовый код"
                                   FontSize="22"
                                   FontAttributes="Bold"
                                   TextColor="{DynamicResource AccentColor}"
                                   VerticalOptions="Center"/>
                        </HorizontalStackLayout>

                        <Border BackgroundColor="#1E1E1E"
                                Padding="15"
                                Stroke="#333"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 8">
                            <Editor x:Name="StarterCodeEditor"
                                    HeightRequest="180"
                                    IsEnabled="False"
                                    TextColor="#D4D4D4"
                                    FontFamily="Consolas"
                                    FontSize="13"
                                    BackgroundColor="Transparent" />
                        </Border>

                        <Button Text="📋 Копировать код"
                                Clicked="OnCopyCodeClicked"
                                BackgroundColor="{DynamicResource AccentColor}"
                                TextColor="White"
                                CornerRadius="8"
                                HeightRequest="45"
                                FontSize="14" />
                    </VerticalStackLayout>
                </Border>

                <!-- Область ответа -->
                <Border BackgroundColor="White"
                        Stroke="{DynamicResource SuccessColor}"
                        StrokeThickness="2"
                        StrokeShape="RoundRectangle 12"
                        Padding="20">
                    <VerticalStackLayout Spacing="15">
                        <HorizontalStackLayout Spacing="10">
                            <Label Text="✍️"
                                   FontSize="28"
                                   VerticalOptions="Center"/>
                            <Label Text="Ваш ответ"
                                   FontSize="22"
                                   FontAttributes="Bold"
                                   TextColor="{DynamicResource SuccessColor}"
                                   VerticalOptions="Center"/>
                        </HorizontalStackLayout>

                        <!-- Текстовый ответ -->
                        <VerticalStackLayout x:Name="TextAnswerSection"
                                             IsVisible="False"
                                             Spacing="10">
                            <Border BackgroundColor="#F8F9FA"
                                    Stroke="#E0E0E0"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 8"
                                    Padding="0">
                                <Editor x:Name="TextAnswerEditor"
                                        HeightRequest="180"
                                        Placeholder="Введите ваш ответ здесь..."
                                        FontSize="15"
                                        BackgroundColor="Transparent"
                                        Margin="15,10"
                                        TextColor="#333" />
                            </Border>
                        </VerticalStackLayout>

                        <!-- Ответ кодом -->
                        <VerticalStackLayout x:Name="CodeAnswerSection"
                                             IsVisible="False"
                                             Spacing="10">
                            <Border BackgroundColor="#1E1E1E"
                                    Stroke="#333"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 8"
                                    Padding="0">
                                <Editor x:Name="CodeAnswerEditor"
                                        HeightRequest="250"
                                        Placeholder="// Напишите ваш код здесь..."
                                        FontFamily="Consolas"
                                        FontSize="14"
                                        TextColor="#D4D4D4"
                                        BackgroundColor="Transparent"
                                        Margin="15,10" />
                            </Border>
                            <HorizontalStackLayout Spacing="12" Margin="0,12,0,0">
                                <Button Text="▶️ Запустить"
                                        Clicked="OnRunCodeClicked"
                                        BackgroundColor="{DynamicResource AccentColor}"
                                        TextColor="White"
                                        CornerRadius="8"
                                        HeightRequest="45"
                                        FontSize="14"
                                        FontAttributes="Bold"
                                        HorizontalOptions="FillAndExpand" />
                                <Button Text="🗑️ Очистить"
                                        Clicked="OnClearCodeClicked"
                                        BackgroundColor="#6C757D"
                                        TextColor="White"
                                        CornerRadius="8"
                                        HeightRequest="45"
                                        FontSize="14" />
                            </HorizontalStackLayout>
                        </VerticalStackLayout>

                        <!-- Загрузка файла -->
                        <VerticalStackLayout x:Name="FileAnswerSection"
                                             IsVisible="False"
                                             Spacing="15">

                            <Button Text="📎 Выбрать файл с решением"
                                    Clicked="OnSelectFileClicked"
                                    BackgroundColor="{DynamicResource PrimaryColor}"
                                    TextColor="White"
                                    CornerRadius="8"
                                    HeightRequest="50"
                                    FontSize="15"
                                    FontAttributes="Bold" />

                            <Border x:Name="FilePreviewSection"
                                   IsVisible="False"
                                   BackgroundColor="#F0F7FF"
                                   Stroke="{DynamicResource PrimaryColor}"
                                   StrokeThickness="2"
                                   StrokeShape="RoundRectangle 8"
                                   Padding="15">
                                <VerticalStackLayout Spacing="12">
                                    <HorizontalStackLayout Spacing="12">
                                        <Label x:Name="FileIconLabel"
                                               Text="📎"
                                               FontSize="32"
                                               VerticalOptions="Center"
                                               TextColor="{DynamicResource PrimaryColor}"/>
                                        <VerticalStackLayout Spacing="4" 
                                                             HorizontalOptions="FillAndExpand"
                                                             VerticalOptions="Center">
                                            <Label x:Name="SelectedFileNameLabel"
                                                   FontSize="16"
                                                   FontAttributes="Bold"
                                                   TextColor="{DynamicResource PrimaryColor}"
                                                   LineBreakMode="TailTruncation"/>
                                            <Label x:Name="SelectedFileSizeLabel"
                                                   FontSize="13"
                                                   TextColor="Gray"/>
                                        </VerticalStackLayout>
                                    </HorizontalStackLayout>

                                    <Button Text="🗑️ Удалить файл"
                                            Clicked="OnRemoveFileClicked"
                                            BackgroundColor="Transparent"
                                            TextColor="#FF4444"
                                            FontSize="14"
                                            HorizontalOptions="End"
                                            BorderColor="#FF4444"
                                            BorderWidth="1"
                                            CornerRadius="8"
                                            Padding="15,8"/>
                                </VerticalStackLayout>
                            </Border>

                            <Label Text="Поддерживаемые форматы: ZIP, PDF, JPG, PNG, TXT, DOCX, PPTX"
                                   FontSize="12"
                                   TextColor="Gray"
                                   Margin="0,4,0,0" />
                        </VerticalStackLayout>

                        <!-- Прогресс отправки -->
                        <Border x:Name="UploadProgressSection" 
                                IsVisible="False"
                                BackgroundColor="#F8F9FA"
                                Padding="15"
                                Stroke="#E0E0E0"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 8">
                            <VerticalStackLayout Spacing="8">
                                <ProgressBar x:Name="UploadProgressBar" 
                                           Progress="0"
                                           ProgressColor="{DynamicResource SuccessColor}"
                                           HeightRequest="6"/>
                                <Label x:Name="UploadStatusLabel" 
                                       Text=""
                                       FontSize="13"
                                       HorizontalOptions="Center"
                                       TextColor="#333"/>
                            </VerticalStackLayout>
                        </Border>
                    </VerticalStackLayout>
                </Border>

                <!-- Подсказка (если есть) -->
                <Border x:Name="HintSection"
                       IsVisible="False"
                       BackgroundColor="#FFF3E0"
                       Stroke="#FF9800"
                       StrokeThickness="2"
                       StrokeShape="RoundRectangle 12"
                       Padding="20">
                    <VerticalStackLayout Spacing="10">
                        <HorizontalStackLayout Spacing="10">
                            <Label Text="💡"
                                   FontSize="28"
                                   VerticalOptions="Center"/>
                            <Label Text="Подсказка"
                                   FontSize="22"
                                   FontAttributes="Bold"
                                   TextColor="#FF9800"
                                   VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                        <Border BackgroundColor="White"
                                Padding="15"
                                Stroke="#FF9800"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 8">
                            <Label x:Name="HintLabel"
                                   FontSize="15"
                                   TextColor="#333"
                                   LineBreakMode="WordWrap" />
                        </Border>
                    </VerticalStackLayout>
                </Border>

                <!-- Прикреплённые файлы задания -->
                <Border x:Name="AttachmentsSection"
                       IsVisible="False"
                       BackgroundColor="White"
                       Stroke="{DynamicResource SecondaryColor}"
                       StrokeThickness="2"
                       StrokeShape="RoundRectangle 12"
                       Padding="20">
                    <VerticalStackLayout Spacing="15">
                        <HorizontalStackLayout Spacing="10">
                            <Label Text="📎"
                                   FontSize="28"
                                   VerticalOptions="Center"/>
                            <Label Text="Материалы к заданию"
                                   FontSize="22"
                                   FontAttributes="Bold"
                                   TextColor="{DynamicResource SecondaryColor}"
                                   VerticalOptions="Center"/>
                        </HorizontalStackLayout>

                        <CollectionView x:Name="AttachmentsCollection"
                                      HeightRequest="200">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Border BackgroundColor="#F8F9FA"
                                            Padding="12"
                                            Margin="0,4"
                                            Stroke="#E0E0E0"
                                            StrokeThickness="1"
                                            StrokeShape="RoundRectangle 8">
                                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                            <Label Grid.Column="0"
                                                   Text="{Binding FileIcon, Converter={StaticResource FileTypeToIconConverter}}"
                                                   FontSize="28"
                                                   VerticalOptions="Center"/>
                                            <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                                <Label Text="{Binding FileName}"
                                                       FontSize="15"
                                                       FontAttributes="Bold"
                                                       LineBreakMode="TailTruncation"/>
                                                <Label Text="{Binding FileSize}"
                                                       FontSize="12"
                                                       TextColor="Gray"/>
                                            </VerticalStackLayout>
                                            <Button Grid.Column="2"
                                                    Text="📥"
                                                    FontSize="22"
                                                    WidthRequest="44"
                                                    HeightRequest="44"
                                                    CornerRadius="22"
                                                    BackgroundColor="{DynamicResource SecondaryColor}"
                                                    TextColor="White"
                                                    Clicked="OnOpenAttachmentClicked"
                                                    CommandParameter="{Binding .}"
                                                    VerticalOptions="Center"/>
                                        </Grid>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnAttachmentTapped" 
                                                                 CommandParameter="{Binding .}" />
                                        </Border.GestureRecognizers>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>

                <!-- Результат отправки -->
                <Border x:Name="ResultSection"
                       IsVisible="False"
                       Padding="20"
                       StrokeThickness="2"
                       StrokeShape="RoundRectangle 12">
                    <VerticalStackLayout Spacing="12">
                        <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                            <Label x:Name="ResultIconLabel"
                                   Text="✅"
                                   FontSize="36"/>
                            <Label x:Name="ResultLabel"
                                   Text="Успех!"
                                   FontSize="22"
                                   FontAttributes="Bold"
                                   VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                        <Label x:Name="FeedbackLabel"
                               FontSize="15"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Оценка (если работа уже проверена) -->
                <Border x:Name="GradeSection"
                       IsVisible="False"
                       BackgroundColor="#E8F5E8"
                       Stroke="#4CAF50"
                       StrokeThickness="2"
                       StrokeShape="RoundRectangle 12"
                       Padding="20">
                    <VerticalStackLayout Spacing="12">
                        <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                            <Label Text="⭐"
                                   FontSize="36"/>
                            <Label x:Name="GradeLabel"
                                   Text="Оценка"
                                   FontSize="22"
                                   FontAttributes="Bold"
                                   TextColor="#4CAF50"
                                   VerticalOptions="Center"/>
                        </HorizontalStackLayout>

                        <Label x:Name="GradeScoreLabel"
                               Text="0 / 100"
                               FontSize="32"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"
                               TextColor="#333"/>

                        <Border BackgroundColor="White"
                                Padding="15"
                                Stroke="#4CAF50"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 8"
                                Margin="0,5">
                            <Label x:Name="TeacherCommentLabel"
                                   Text="Комментарий преподавателя"
                                   FontSize="15"
                                   HorizontalOptions="Center"
                                   HorizontalTextAlignment="Center"
                                   TextColor="#666"/>
                        </Border>

                        <Label x:Name="GradedByLabel"
                               Text="Преподаватель"
                               FontSize="13"
                               HorizontalOptions="Center"
                               TextColor="Gray"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Кнопка отправки -->
                <Button x:Name="SubmitButton"
                        Text=" Отправить на проверку"
                        Clicked="OnSubmitClicked"
                        BackgroundColor="{DynamicResource SuccessColor}"
                        TextColor="Black"
                        CornerRadius="8"
                        HeightRequest="55"
                        FontSize="16"
                        FontAttributes="Bold"
                        Margin="0,10,0,0"/>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>