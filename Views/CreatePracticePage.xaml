<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="EducationalPlatform.Views.CreatePracticePage"
             Title="Создание практики"
             BackgroundColor="{DynamicResource BackgroundColor}">

    <ContentPage.Resources>
        <Style x:Key="SectionTitleStyle" TargetType="Label">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontAttributes" Value="Bold"/>
            <Setter Property="TextColor" Value="{DynamicResource PrimaryColor}"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*">
        <!-- Современный заголовок -->
        <Border Grid.Row="0"
                BackgroundColor="{DynamicResource PrimaryColor}"
                Padding="20,15"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 0,0,0,20">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Button Grid.Column="0"
                        Text="←"
                        Clicked="OnBackClicked"
                        BackgroundColor="Transparent"
                        TextColor="White"
                        FontSize="20"
                        WidthRequest="40"
                        HeightRequest="40" />
                <Label Grid.Column="1"
                       Text="Создание практического задания" 
                       FontSize="20" 
                       FontAttributes="Bold" 
                       TextColor="White" 
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />
                <Label Grid.Column="2"
                       Text="✏️"
                       FontSize="20"
                       TextColor="White"
                       VerticalOptions="Center"
                       Margin="0,0,10,0" />
            </Grid>
        </Border>

        <ScrollView Grid.Row="1" BackgroundColor="{DynamicResource BackgroundColor}">
            <VerticalStackLayout Spacing="20" Padding="20">

                <Border BackgroundColor="White"
                        Stroke="#E0E0E0"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 12"
                        Padding="20">
                    <VerticalStackLayout Spacing="18">

                        <!-- Название задания -->
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Название задания:" Style="{StaticResource SectionTitleStyle}"/>
                            <Border BackgroundColor="#F8F9FA"
                                    Stroke="#E0E0E0"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 8"
                                    Padding="0">
                                <Entry x:Name="TitleEntry" 
                                       Placeholder="Введите название задания"
                                       BackgroundColor="Transparent"
                                       Margin="15,0"
                                       FontSize="16"
                                       HeightRequest="50" />
                            </Border>
                        </VerticalStackLayout>

                        <!-- Описание -->
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Описание:" Style="{StaticResource SectionTitleStyle}"/>
                            <Border BackgroundColor="#F8F9FA"
                                    Stroke="#E0E0E0"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 8"
                                    Padding="0">
                                <Editor x:Name="DescriptionEditor" 
                                        HeightRequest="100"
                                        Placeholder="Введите описание задания..."
                                        BackgroundColor="Transparent"
                                        Margin="15,10"
                                        FontSize="14" />
                            </Border>
                        </VerticalStackLayout>

                        <!-- Тип ответа -->
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Тип ответа:" Style="{StaticResource SectionTitleStyle}"/>
                            <Border BackgroundColor="#F8F9FA"
                                    Stroke="#E0E0E0"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 8"
                                    Padding="0">
                                <Picker x:Name="AnswerTypePicker"
                                        BackgroundColor="Transparent"
                                        Margin="15,0"
                                        FontSize="16"
                                        HeightRequest="70"
                                        Title="Выберите тип ответа">
                                    <Picker.Items>
                                        <x:String>text</x:String>
                                        <x:String>code</x:String>
                                        <x:String>file</x:String>
                                    </Picker.Items>
                                </Picker>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Для программирования -->
                        <StackLayout x:Name="CodeSection" IsVisible="False">
                            <VerticalStackLayout Spacing="8">
                                <Label Text="Стартовый код:" Style="{StaticResource SectionTitleStyle}"/>
                                <Border BackgroundColor="#1E1E1E"
                                        Stroke="#333"
                                        StrokeThickness="1"
                                        StrokeShape="RoundRectangle 8"
                                        Padding="0">
                                    <Editor x:Name="StarterCodeEditor"
                                            HeightRequest="150"
                                            BackgroundColor="Transparent"
                                            Margin="15,10"
                                            FontSize="14"
                                            FontFamily="Consolas"
                                            TextColor="White"
                                            Placeholder="// Введите стартовый код..."
                                            PlaceholderColor="#888" />
                                </Border>
                            </VerticalStackLayout>
                        </StackLayout>

                        <!-- Ожидаемый ответ -->
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Ожидаемый ответ/решение:" Style="{StaticResource SectionTitleStyle}"/>
                            <Border BackgroundColor="#F8F9FA"
                                    Stroke="#E0E0E0"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 8"
                                    Padding="0">
                                <Editor x:Name="ExpectedAnswerEditor"
                                        HeightRequest="100"
                                        Placeholder="Введите ожидаемый ответ..."
                                        BackgroundColor="Transparent"
                                        Margin="15,10"
                                        FontSize="14" />
                            </Border>
                        </VerticalStackLayout>

                        <!-- Подсказка -->
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Подсказка:" Style="{StaticResource SectionTitleStyle}"/>
                            <Border BackgroundColor="#F8F9FA"
                                    Stroke="#E0E0E0"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 8"
                                    Padding="0">
                                <Editor x:Name="HintEditor"
                                        HeightRequest="80"
                                        Placeholder="Введите подсказку для студентов..."
                                        BackgroundColor="Transparent"
                                        Margin="15,10"
                                        FontSize="14" />
                            </Border>
                        </VerticalStackLayout>

                        <!-- Секция файлов-ответов -->
                        <StackLayout x:Name="FileSettingsSection" IsVisible="False" Spacing="15">
                            <Border BackgroundColor="#F0F7FF"
                                    Stroke="{DynamicResource PrimaryColor}"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 10"
                                    Padding="15">
                                <VerticalStackLayout Spacing="12">
                                    <Label Text="⚙️ Настройки для файлов-ответов"
                                           FontSize="16"
                                           FontAttributes="Bold"
                                           TextColor="{DynamicResource PrimaryColor}"/>

                                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                                        <Label Text="Макс. размер:" 
                                               VerticalOptions="Center"
                                               FontSize="14"/>
                                        <Entry x:Name="MaxFileSizeEntry" 
                                               Grid.Column="1"
                                               Text="10" 
                                               Keyboard="Numeric"
                                               BackgroundColor="White"
                                               HeightRequest="40"
                                               FontSize="14"/>
                                        <Label Grid.Column="2"
                                               Text="МБ"
                                               VerticalOptions="Center"
                                               FontSize="14"/>
                                    </Grid>

                                    <Label Text="Разрешенные типы файлов:" 
                                           FontSize="14"
                                           FontAttributes="Bold"
                                           Margin="0,5,0,5"/>

                                    <!-- Заменил WrapLayout на Grid -->
                                    <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto" RowSpacing="10" ColumnSpacing="10">
                                        <!-- Первая строка -->
                                        <HorizontalStackLayout Grid.Row="0" Grid.Column="0">
                                            <CheckBox x:Name="ZipCheckBox" IsChecked="True" />
                                            <Label Text="ZIP" VerticalOptions="Center"/>
                                        </HorizontalStackLayout>

                                        <HorizontalStackLayout Grid.Row="0" Grid.Column="1">
                                            <CheckBox x:Name="ImageCheckBox" IsChecked="True" />
                                            <Label Text="Изображения" VerticalOptions="Center"/>
                                        </HorizontalStackLayout>

                                        <HorizontalStackLayout Grid.Row="0" Grid.Column="2">
                                            <CheckBox x:Name="PdfCheckBox" IsChecked="True" />
                                            <Label Text="PDF" VerticalOptions="Center"/>
                                        </HorizontalStackLayout>

                                        <!-- Вторая строка -->
                                        <HorizontalStackLayout Grid.Row="1" Grid.Column="0">
                                            <CheckBox x:Name="DocCheckBox" IsChecked="False" />
                                            <Label Text="Word" VerticalOptions="Center"/>
                                        </HorizontalStackLayout>

                                        <HorizontalStackLayout Grid.Row="1" Grid.Column="1">
                                            <CheckBox x:Name="TxtCheckBox" IsChecked="False" />
                                            <Label Text="TXT" VerticalOptions="Center"/>
                                        </HorizontalStackLayout>

                                        <HorizontalStackLayout Grid.Row="1" Grid.Column="2">
                                            <CheckBox x:Name="PowerPointCheckBox" IsChecked="False" />
                                            <Label Text="PowerPoint" VerticalOptions="Center"/>
                                        </HorizontalStackLayout>
                                    </Grid>
                                </VerticalStackLayout>
                            </Border>
                        </StackLayout>

                        <!-- Прикрепленные файлы задания -->
                        <Border BackgroundColor="#F0F7FF"
                                Stroke="{DynamicResource PrimaryColor}"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 10"
                                Padding="15">
                            <VerticalStackLayout Spacing="12">
                                <Label Text="📎 Прикрепленные файлы задания:" 
                                       FontSize="16" 
                                       FontAttributes="Bold"
                                       TextColor="{DynamicResource PrimaryColor}" />

                                <Label Text="Макс. размер: 50 МБ. Поддерживаемые: ZIP, PDF, Word, PowerPoint, изображения" 
                                       FontSize="12" 
                                       TextColor="Gray" />

                                <Button Text="Выбрать файлы" 
                                        Clicked="OnSelectFilesClicked"
                                        BackgroundColor="{DynamicResource SecondaryColor}"
                                        TextColor="White"
                                        CornerRadius="8"
                                        HeightRequest="45"
                                        FontSize="14" />

                                <CollectionView x:Name="AttachmentsCollection" 
                                                HeightRequest="200"
                                                IsVisible="False"
                                                BackgroundColor="White">
                                    <CollectionView.ItemTemplate>
                                        <DataTemplate>
                                            <Border BackgroundColor="White"
                                                    Stroke="#E0E0E0"
                                                    StrokeThickness="1"
                                                    StrokeShape="RoundRectangle 8"
                                                    Padding="10"
                                                    Margin="0,4">
                                                <Grid ColumnDefinitions="Auto,*,Auto,Auto" 
                                                      ColumnSpacing="10">
                                                    <Label Grid.Column="0"
                                                           Text="{Binding FileIcon}"
                                                           FontSize="20"
                                                           VerticalOptions="Center"/>

                                                    <VerticalStackLayout Grid.Column="1" Spacing="2">
                                                        <Label Text="{Binding FileName}" 
                                                               FontSize="14"
                                                               FontAttributes="Bold"
                                                               LineBreakMode="TailTruncation"/>
                                                        <Label Text="{Binding FileSizeFormatted}" 
                                                               FontSize="11"
                                                               TextColor="Gray"/>
                                                    </VerticalStackLayout>

                                                    <Label Grid.Column="2"
                                                           Text="{Binding StatusIcon}"
                                                           FontSize="16"
                                                           VerticalOptions="Center"
                                                           IsVisible="{Binding IsUploading}"/>

                                                    <Button Grid.Column="3" 
                                                            Text="🗑️"
                                                            Clicked="OnRemoveAttachmentClicked" 
                                                            CommandParameter="{Binding .}"
                                                            BackgroundColor="Transparent"
                                                            TextColor="Red"
                                                            FontSize="16"
                                                            WidthRequest="40"
                                                            HeightRequest="40" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>
                                </CollectionView>

                                <ProgressBar x:Name="UploadProgressBar" 
                                           Progress="0"
                                           IsVisible="False"
                                           HeightRequest="4"
                                           ProgressColor="{DynamicResource PrimaryColor}"/>
                                <Label x:Name="UploadStatusLabel" 
                                       Text=""
                                       FontSize="12"
                                       IsVisible="False"
                                       HorizontalOptions="Center"/>

                                <Button x:Name="ClearAllButton"
                                        Text="Очистить все файлы" 
                                        Clicked="OnClearAllFilesClicked"
                                        BackgroundColor="#FF6B6B"
                                        TextColor="White"
                                        IsVisible="False"
                                        CornerRadius="8"
                                        HeightRequest="40" />
                            </VerticalStackLayout>
                        </Border>

                        <!-- Кнопки действий -->
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="15" Margin="0,10,0,0">
                            <Button Text="Назад"
                                    Clicked="OnBackClicked"
                                    BackgroundColor="#6C757D"
                                    TextColor="White"
                                    CornerRadius="8"
                                    HeightRequest="50"
                                    FontSize="16" />
                            <Button Text="Создать практику"
                                    Clicked="OnCreateClicked"
                                    BackgroundColor="{DynamicResource PrimaryColor}"
                                    TextColor="White"
                                    CornerRadius="8"
                                    HeightRequest="50"
                                    FontSize="16"
                                    FontAttributes="Bold" />
                        </Grid>

                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>
        <Grid x:Name="LoadingOverlay"
          Grid.RowSpan="2"
          BackgroundColor="#80000000"
          IsVisible="False"
          InputTransparent="True">
                <VerticalStackLayout Spacing="20"
                            VerticalOptions="Center"
                            HorizontalOptions="Center">
                    <ActivityIndicator x:Name="LoadingIndicator"
                               IsRunning="False"
                               Color="White"
                               HeightRequest="50"
                               WidthRequest="50"/>
                    <Label x:Name="LoadingLabel"
                   Text="Загрузка..."
                   TextColor="White"
                   FontSize="16"/>
            </VerticalStackLayout>
        </Grid>
    </Grid>
</ContentPage>