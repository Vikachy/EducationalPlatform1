<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:EducationalPlatform.Converters"
             x:Class="EducationalPlatform.Views.StudentChatsPage"
             Title="{Binding Title}"
             BackgroundColor="{DynamicResource BackgroundColor}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:GreaterThanZeroConverter x:Key="GreaterThanZeroConverter" />
            <converters:InverseBoolConverter x:Key="InverseBoolConverter" />
            <converters:NotNullConverter x:Key="NotNullConverter" />
            <converters:AvatarToImageSourceConverter x:Key="AvatarConverter" />
            <converters:OnlineStatusColorConverter x:Key="OnlineStatusColor" />
            <converters:MoscowTimeConverter x:Key="MoscowTimeConverter" />
            <converters:ColorConverter x:Key="ColorConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*">
        <Grid x:Name="LoadingOverlay"
              Grid.RowSpan="2"
              BackgroundColor="#80000000"
              IsVisible="False">
            <VerticalStackLayout Spacing="20"
                                VerticalOptions="Center"
                                HorizontalOptions="Center">
                <ActivityIndicator x:Name="LoadingIndicator"
                                   IsRunning="False"
                                   Color="White"
                                   HeightRequest="50"
                                   WidthRequest="50"/>
                <Label x:Name="LoadingLabel"
                       Text="Загрузка чатов..."
                       TextColor="White"
                       FontSize="16"/>
            </VerticalStackLayout>
        </Grid>

        <Border Grid.Row="0" 
                BackgroundColor="{DynamicResource PrimaryColor}"
                Padding="20,15"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 0,0,0,20">
            <Grid ColumnDefinitions="*,Auto" VerticalOptions="Center">
                <Label Grid.Column="0" 
                       x:Name="HeaderLabel"
                       Text="💬 Мои чаты" 
                       FontSize="22" 
                       FontAttributes="Bold" 
                       TextColor="White" />
                <Button Grid.Column="1" 
                        x:Name="MyCoursesButton"
                        Text="📚 Мои курсы" 
                        Clicked="OnMyCoursesClicked"
                        BackgroundColor="White" 
                        TextColor="{DynamicResource PrimaryColor}" 
                        CornerRadius="20" 
                        Padding="12,6"
                        FontSize="12" />
            </Grid>
        </Border>

        <CollectionView Grid.Row="1"
                        x:Name="ChatsCollectionView"
                        ItemsSource="{Binding Chats}"
                        SelectionMode="Single"
                        SelectionChanged="OnChatSelected"
                        Margin="10">
            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center" 
                                     VerticalOptions="Center" 
                                     Spacing="20"
                                     Padding="20">
                    <Label Text="💬" 
                           FontSize="64" 
                           HorizontalOptions="Center" 
                           TextColor="#999" />
                    <Label Text="У вас пока нет чатов"
                           FontSize="18"
                           TextColor="#999"
                           HorizontalOptions="Center" />
                    <Label Text="Запишитесь на курсы, чтобы начать общение"
                           FontSize="14"
                           TextColor="#999"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Margin="5,8"
                            Padding="15"
                            BackgroundColor="White"
                            Stroke="{DynamicResource PrimaryColor}"
                            StrokeThickness="{Binding HasUnreadMessages, Converter={StaticResource GreaterThanZeroConverter}}"
                            StrokeShape="RoundRectangle 15">
                        <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto,Auto">

                            <Border Grid.Row="0" Grid.RowSpan="3" Grid.Column="0"
                                    WidthRequest="55"
                                    HeightRequest="55"
                                    Stroke="{Binding FrameColor, Converter={StaticResource ColorConverter}}"
                                    StrokeThickness="2"
                                    StrokeShape="RoundRectangle 27.5"
                                    BackgroundColor="White"
                                    Margin="0,0,15,0">
                                <Image Source="{Binding Avatar, Converter={StaticResource AvatarConverter}}"
                                       Aspect="AspectFill"
                                       WidthRequest="51"
                                       HeightRequest="51" />
                            </Border>

                            <HorizontalStackLayout Grid.Row="0" Grid.Column="1"
                                                   Spacing="4"
                                                   VerticalOptions="End">
                                <Label Text="{Binding ChatName}"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       TextColor="{DynamicResource TextColor}"
                                       LineBreakMode="TailTruncation" />
                                <Label Text="{Binding UserEmoji}"
                                       FontSize="16"
                                       IsVisible="{Binding UserEmoji, Converter={StaticResource NotNullConverter}}" />
                            </HorizontalStackLayout>

                            <Label Grid.Row="0" Grid.Column="2"
                                   Text="{Binding LastMessageTime, Converter={StaticResource MoscowTimeConverter}}"
                                   FontSize="11"
                                   TextColor="Gray"
                                   VerticalOptions="End" />

                            <Label Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"
                                   Text="{Binding LastMessage}"
                                   FontSize="13"
                                   TextColor="#666"
                                   MaxLines="2"
                                   LineBreakMode="TailTruncation"
                                   Margin="0,2,0,2" />

                            <Grid Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2"
                                  ColumnDefinitions="*,Auto">
                                <Label Grid.Column="0"
                                       Text="{Binding ChatTypeDisplay}"
                                       FontSize="11"
                                       TextColor="{DynamicResource PrimaryColor}" />
                                <Border Grid.Column="1"
                                        BackgroundColor="#FF3B30"
                                        Padding="8,4"
                                        IsVisible="{Binding HasUnreadMessages}">
                                    <Label Text="{Binding UnreadMessages}"
                                           FontSize="11"
                                           FontAttributes="Bold"
                                           TextColor="White" />
                                </Border>
                            </Grid>

                            <Border Grid.Row="0" Grid.Column="1"
                                    BackgroundColor="{Binding IsOnline, Converter={StaticResource OnlineStatusColor}}"
                                    WidthRequest="12"
                                    HeightRequest="12"
                                    HorizontalOptions="Start"
                                    Margin="0,0,0,0"
                                    IsVisible="{Binding ShowOnlineIndicator}" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>