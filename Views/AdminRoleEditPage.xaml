<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="EducationalPlatform.Views.AdminRoleEditPage"
             Title="Редактирование роли"
             BackgroundColor="{DynamicResource BackgroundColor}">

    <Grid RowDefinitions="Auto,*">
        <!-- Заголовок -->
        <Border Grid.Row="0"
                BackgroundColor="{DynamicResource PrimaryColor}"
                Padding="20,15"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 0,0,0,20">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Button Grid.Column="0"
                        Text="←"
                        Clicked="OnBackClicked"
                        BackgroundColor="Transparent"
                        TextColor="White"
                        FontSize="20"
                        WidthRequest="40"
                        HeightRequest="40" />
                <Label Grid.Column="1"
                       Text="Редактирование роли" 
                       FontSize="20" 
                       FontAttributes="Bold" 
                       TextColor="White" 
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />
                <Button Grid.Column="2"
                        Text="💾"
                        Clicked="OnSaveClicked"
                        BackgroundColor="Transparent"
                        TextColor="White"
                        FontSize="24"
                        WidthRequest="40"
                        HeightRequest="40" />
            </Grid>
        </Border>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20" Spacing="20">
                <Border BackgroundColor="White"
                        Stroke="{DynamicResource PrimaryColor}"
                        StrokeThickness="2"
                        StrokeShape="RoundRectangle 12"
                        Padding="20">
                    <VerticalStackLayout Spacing="20">
                        <Label Text="Информация о роли"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="{DynamicResource PrimaryColor}"/>

                        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto" RowSpacing="15" ColumnSpacing="15">
                            <Label Grid.Row="0" Grid.Column="0"
                                   Text="Название:"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="#666"
                                   VerticalOptions="Center"/>
                            <Border Grid.Row="0" Grid.Column="1"
                                    BackgroundColor="#F8F9FA"
                                    Stroke="#E0E0E0"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 8"
                                    Padding="0">
                                <Entry x:Name="RoleNameEntry"
                                       BackgroundColor="Transparent"
                                       Margin="15,0"
                                       FontSize="14"
                                       HeightRequest="45"/>
                            </Border>

                            <Label Grid.Row="1" Grid.Column="0"
                                   Text="Описание:"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="#666"
                                   VerticalOptions="Center"/>
                            <Border Grid.Row="1" Grid.Column="1"
                                    BackgroundColor="#F8F9FA"
                                    Stroke="#E0E0E0"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 8"
                                    Padding="0">
                                <Editor x:Name="RoleDescriptionEditor"
                                        HeightRequest="80"
                                        BackgroundColor="Transparent"
                                        Margin="15,10"
                                        FontSize="14"/>
                            </Border>
                        </Grid>

                        <Label Text="Права доступа"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="{DynamicResource SecondaryColor}"/>

                        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="15" ColumnSpacing="15">
                            <CheckBox Grid.Row="0" Grid.Column="0" x:Name="CanCreateCoursesCheckBox"/>
                            <Label Grid.Row="0" Grid.Column="1" Text="Создание курсов" VerticalOptions="Center"/>

                            <CheckBox Grid.Row="1" Grid.Column="0" x:Name="CanManageUsersCheckBox"/>
                            <Label Grid.Row="1" Grid.Column="1" Text="Управление пользователями" VerticalOptions="Center"/>

                            <CheckBox Grid.Row="2" Grid.Column="0" x:Name="CanManageGroupsCheckBox"/>
                            <Label Grid.Row="2" Grid.Column="1" Text="Управление группами" VerticalOptions="Center"/>

                            <CheckBox Grid.Row="3" Grid.Column="0" x:Name="CanManageSystemCheckBox"/>
                            <Label Grid.Row="3" Grid.Column="1" Text="Управление системой" VerticalOptions="Center"/>

                            <CheckBox Grid.Row="4" Grid.Column="0" x:Name="CanGradeTestsCheckBox"/>
                            <Label Grid.Row="4" Grid.Column="1" Text="Оценивание тестов" VerticalOptions="Center"/>

                            <CheckBox Grid.Row="5" Grid.Column="0" x:Name="CanManageContentCheckBox"/>
                            <Label Grid.Row="5" Grid.Column="1" Text="Управление контентом" VerticalOptions="Center"/>

                            <CheckBox Grid.Row="6" Grid.Column="0" x:Name="CanPublishNewsCheckBox"/>
                            <Label Grid.Row="6" Grid.Column="1" Text="Публикация новостей" VerticalOptions="Center"/>
                        </Grid>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>