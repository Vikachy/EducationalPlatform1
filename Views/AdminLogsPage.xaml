<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:EducationalPlatform.Converters"
             x:Class="EducationalPlatform.Views.AdminLogsPage"
             Title="Системные логи"
             BackgroundColor="{DynamicResource BackgroundColor}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:DateTimeToRelativeConverter x:Key="DateTimeToRelativeConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*">
        <!-- Заголовок -->
        <Border Grid.Row="0"
                BackgroundColor="{DynamicResource PrimaryColor}"
                Padding="20,15"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 0,0,0,20">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Button Grid.Column="0"
                        Text="←"
                        Clicked="OnBackClicked"
                        BackgroundColor="Transparent"
                        TextColor="White"
                        FontSize="20"
                        WidthRequest="40"
                        HeightRequest="40" />
                <Label Grid.Column="1"
                       Text="Системные логи" 
                       FontSize="20" 
                       FontAttributes="Bold" 
                       TextColor="White" 
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />
                <Button Grid.Column="2"
                        Text="🔄"
                        Clicked="OnRefreshClicked"
                        BackgroundColor="White"
                        TextColor="{DynamicResource PrimaryColor}"
                        FontSize="18"
                        WidthRequest="40"
                        HeightRequest="40"
                        CornerRadius="20" />
            </Grid>
        </Border>

        <Grid Grid.Row="1" RowDefinitions="Auto,Auto,*">
            <!-- Фильтры -->
            <ScrollView Grid.Row="0" Orientation="Horizontal" Margin="20,20,20,10">
                <HorizontalStackLayout Spacing="10">
                    <Button Text="Все"
                            Clicked="OnFilterAllClicked"
                            BackgroundColor="{DynamicResource PrimaryColor}"
                            TextColor="White"
                            HeightRequest="35"
                            CornerRadius="15"
                            FontSize="12"
                            Padding="15,0"/>
                    <Button Text="Входы"
                            Clicked="OnFilterLoginsClicked"
                            BackgroundColor="#4CAF50"
                            TextColor="White"
                            HeightRequest="35"
                            CornerRadius="15"
                            FontSize="12"
                            Padding="15,0"/>
                    <Button Text="Пользователи"
                            Clicked="OnFilterUsersClicked"
                            BackgroundColor="#2196F3"
                            TextColor="White"
                            HeightRequest="35"
                            CornerRadius="15"
                            FontSize="12"
                            Padding="15,0"/>
                    <Button Text="Курсы"
                            Clicked="OnFilterCoursesClicked"
                            BackgroundColor="#FF9800"
                            TextColor="White"
                            HeightRequest="35"
                            CornerRadius="15"
                            FontSize="12"
                            Padding="15,0"/>
                    <Button Text="Ошибки"
                            Clicked="OnFilterErrorsClicked"
                            BackgroundColor="#F44336"
                            TextColor="White"
                            HeightRequest="35"
                            CornerRadius="15"
                            FontSize="12"
                            Padding="15,0"/>
                </HorizontalStackLayout>
            </ScrollView>

            <!-- Статистика логов -->
            <Grid Grid.Row="1" ColumnDefinitions="*,*,*" ColumnSpacing="10" Margin="20,10">
                <Border Grid.Column="0"
                        BackgroundColor="#E3F2FD"
                        Padding="10"
                        StrokeShape="RoundRectangle 8">
                    <VerticalStackLayout>
                        <Label Text="Сегодня" FontSize="11" TextColor="#1976D2"/>
                        <Label x:Name="TodayLogsLabel" Text="0" FontSize="16" FontAttributes="Bold" TextColor="#1976D2"/>
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Column="1"
                        BackgroundColor="#E8F5E8"
                        Padding="10"
                        StrokeShape="RoundRectangle 8">
                    <VerticalStackLayout>
                        <Label Text="Неделя" FontSize="11" TextColor="#4CAF50"/>
                        <Label x:Name="WeekLogsLabel" Text="0" FontSize="16" FontAttributes="Bold" TextColor="#4CAF50"/>
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Column="2"
                        BackgroundColor="#FFEBEE"
                        Padding="10"
                        StrokeShape="RoundRectangle 8">
                    <VerticalStackLayout>
                        <Label Text="Ошибки" FontSize="11" TextColor="#F44336"/>
                        <Label x:Name="ErrorLogsLabel" Text="0" FontSize="16" FontAttributes="Bold" TextColor="#F44336"/>
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <!-- Список логов -->
            <CollectionView Grid.Row="2"
                          x:Name="LogsCollectionView"
                          Margin="20,10,20,20"
                          ItemsSource="{Binding Logs}"
                          EmptyView="Нет записей">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,3"
                                BackgroundColor="White"
                                Stroke="#E0E0E0"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 8"
                                Padding="12">
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                <Border Grid.Column="0"
                                        BackgroundColor="{Binding Color}"
                                        WidthRequest="40"
                                        HeightRequest="40"
                                        StrokeShape="RoundRectangle 8">
                                    <Label Text="{Binding Icon}"
                                           FontSize="20"
                                           TextColor="White"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"/>
                                </Border>
                                <VerticalStackLayout Grid.Column="1" Spacing="4">
                                    <Label Text="{Binding Action}" 
                                           FontSize="14" 
                                           FontAttributes="Bold"
                                           TextColor="#333"/>
                                    <Label Text="{Binding Details}" 
                                           FontSize="12" 
                                           TextColor="#666"/>
                                    <Grid ColumnDefinitions="*,Auto">
                                        <Label Grid.Column="0"
                                               Text="{Binding User}" 
                                               FontSize="11" 
                                               TextColor="{DynamicResource PrimaryColor}"/>
                                        <Label Grid.Column="1"
                                               Text="{Binding Time, Converter={StaticResource DateTimeToRelativeConverter}}" 
                                               FontSize="11" 
                                               TextColor="Gray"/>
                                    </Grid>
                                </VerticalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>
    </Grid>
</ContentPage>