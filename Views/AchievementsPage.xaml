<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:EducationalPlatform.Converters"
             x:Class="EducationalPlatform.Views.AchievementsPage"
             Title="Достижения"
             BackgroundColor="{DynamicResource BackgroundColor}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:NotNullConverter x:Key="NotNullConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*">
        <!-- Заголовок -->
        <Border Grid.Row="0" 
                BackgroundColor="{DynamicResource PrimaryColor}"
                Padding="20,15"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 0,0,0,20">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Button Grid.Column="0"
                        Text="←"
                        Clicked="OnBackClicked"
                        BackgroundColor="Transparent"
                        TextColor="White"
                        FontSize="24"
                        WidthRequest="45"
                        HeightRequest="45"
                        CornerRadius="22" />
                <Label Grid.Column="1"
                       Text="Мои достижения"
                       FontSize="22"
                       TextColor="White"
                       FontAttributes="Bold"
                       VerticalOptions="Center"
                       HorizontalOptions="Center" />
                <Label Grid.Column="2"
                       x:Name="CountLabel"
                       Text="0"
                       FontSize="16"
                       TextColor="White"
                       FontAttributes="Bold"
                       VerticalOptions="Center"
                       HorizontalOptions="End"
                       Margin="0,0,10,0" />
            </Grid>
        </Border>

        <!-- Список достижений -->
        <CollectionView Grid.Row="1"
                        x:Name="AchievementsCollection"
                        ItemsSource="{Binding .}"
                        SelectionMode="None"
                        BackgroundColor="{DynamicResource BackgroundColor}"
                        Margin="10">
            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center" 
                                     VerticalOptions="Center" 
                                     Spacing="20"
                                     Padding="20">
                    <Label Text="🏆" 
                           FontSize="64" 
                           HorizontalOptions="Center" 
                           TextColor="#999" />
                    <Label Text="У вас пока нет достижений"
                           FontSize="18"
                           TextColor="#999"
                           HorizontalOptions="Center" />
                    <Label Text="Проходите курсы и участвуйте в конкурсах, чтобы получить их!"
                           FontSize="14"
                           TextColor="#999"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Margin="10,5"
                            Padding="15"
                            BackgroundColor="White"
                            Stroke="{DynamicResource AccentColor}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 12">
                        <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto">
                            <!-- Иконка -->
                            <Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="0"
                                    BackgroundColor="{DynamicResource AccentColor}"
                                    WidthRequest="60"
                                    HeightRequest="60"
                                    Margin="0,0,15,0">
                                <Label Text="{Binding Icon}"
                                       FontSize="30"
                                       TextColor="White"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />
                            </Border>

                            <!-- Название -->
                            <Label Grid.Row="0" Grid.Column="1"
                                   Text="{Binding Name}"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="{DynamicResource TextColor}"
                                   VerticalOptions="End" />

                            <!-- Дата получения -->
                            <Label Grid.Row="1" Grid.Column="1"
                                   Text="{Binding EarnedDate, StringFormat='Получено: {0:dd.MM.yyyy}'}"
                                   FontSize="12"
                                   TextColor="#666"
                                   VerticalOptions="Start" />

                            <!-- Награда -->
                            <Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="2"
                                    BackgroundColor="#FFD700"
                                    Padding="8,4"
                                    VerticalOptions="Center">
                                <Label Text="{Binding RewardCurrency, StringFormat='{0} 🪙'}"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       TextColor="#8B4513" />
                            </Border>

                            <!-- Описание (на всю ширину) -->
                            <Label Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3"
                                   Text="{Binding Description}"
                                   FontSize="14"
                                   TextColor="#666"
                                   Margin="0,10,0,0"
                                   IsVisible="{Binding Description, Converter={StaticResource NotNullConverter}}" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>