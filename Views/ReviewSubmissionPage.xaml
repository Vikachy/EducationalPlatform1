<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:EducationalPlatform.Converters"
             x:Class="EducationalPlatform.Views.ReviewSubmissionPage"
             Title="Проверка работы"
             BackgroundColor="{DynamicResource BackgroundColor}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:FileTypeToIconConverter x:Key="FileTypeToIconConverter" />
            <converters:ScoreToColorConverter x:Key="ScoreToColorConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*">
        <!-- Индикатор загрузки -->
        <Grid x:Name="LoadingOverlay"
              Grid.RowSpan="2"
              BackgroundColor="#80000000"
              IsVisible="False"
              InputTransparent="True">
            <VerticalStackLayout Spacing="20"
                                VerticalOptions="Center"
                                HorizontalOptions="Center">
                <ActivityIndicator x:Name="LoadingIndicator"
                                   IsRunning="False"
                                   Color="White"
                                   HeightRequest="50"
                                   WidthRequest="50"/>
                <Label x:Name="LoadingLabel"
                       Text="Загрузка..."
                       TextColor="White"
                       FontSize="16"/>
            </VerticalStackLayout>
        </Grid>

        <!-- Заголовок -->
        <Border Grid.Row="0"
                BackgroundColor="{DynamicResource PrimaryColor}"
                Padding="20,15"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 0,0,0,20">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Button Grid.Column="0"
                        Text="←"
                        Clicked="OnBackClicked"
                        BackgroundColor="Transparent"
                        TextColor="White"
                        FontSize="20"
                        WidthRequest="40"
                        HeightRequest="40" />
                <Label Grid.Column="1"
                       Text="Проверка работы" 
                       FontSize="20" 
                       FontAttributes="Bold" 
                       TextColor="White" 
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />
                <Label Grid.Column="2"
                       Text="📝"
                       FontSize="20"
                       TextColor="White"
                       VerticalOptions="Center"
                       Margin="0,0,10,0" />
            </Grid>
        </Border>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20" Spacing="20">

                <!-- Карточка с информацией о студенте -->
                <Border BackgroundColor="White"
                        Stroke="{DynamicResource PrimaryColor}"
                        StrokeThickness="2"
                        StrokeShape="RoundRectangle 12"
                        Padding="20">
                    <VerticalStackLayout Spacing="15">
                        <HorizontalStackLayout Spacing="10">
                            <Label Text="👤"
                                   FontSize="28"
                                   VerticalOptions="Center"/>
                            <Label Text="Информация о студенте"
                                   FontSize="20"
                                   FontAttributes="Bold"
                                   TextColor="{DynamicResource PrimaryColor}"
                                   VerticalOptions="Center"/>
                        </HorizontalStackLayout>

                        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="12" ColumnSpacing="15">
                            <!-- Строка 1: Студент -->
                            <Label Grid.Row="0" Grid.Column="0"
                                   Text="Студент:"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="#666"/>
                            <Label Grid.Row="0" Grid.Column="1"
                                   x:Name="StudentNameLabel"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   TextColor="#333"/>

                            <!-- Строка 2: Курс -->
                            <Label Grid.Row="1" Grid.Column="0"
                                   Text="Курс:"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="#666"/>
                            <Label Grid.Row="1" Grid.Column="1"
                                   x:Name="CourseNameLabel"
                                   FontSize="15"
                                   TextColor="#333"/>

                            <!-- Строка 3: Урок -->
                            <Label Grid.Row="2" Grid.Column="0"
                                   Text="Урок:"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="#666"/>
                            <Label Grid.Row="2" Grid.Column="1"
                                   x:Name="LessonTitleLabel"
                                   FontSize="15"
                                   TextColor="#333"
                                   LineBreakMode="WordWrap"/>

                            <!-- Строка 4: Дата -->
                            <Label Grid.Row="3" Grid.Column="0"
                                   Text="Отправлено:"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="#666"/>
                            <Label Grid.Row="3" Grid.Column="1"
                                   x:Name="SubmissionDateLabel"
                                   FontSize="14"
                                   TextColor="#666"/>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Ответ студента -->
                <Border BackgroundColor="White"
                        Stroke="#FF9800"
                        StrokeThickness="2"
                        StrokeShape="RoundRectangle 12"
                        Padding="20">
                    <VerticalStackLayout Spacing="15">
                        <HorizontalStackLayout Spacing="10">
                            <Label Text="📋"
                                   FontSize="28"
                                   VerticalOptions="Center"/>
                            <Label Text="Ответ студента"
                                   FontSize="20"
                                   FontAttributes="Bold"
                                   TextColor="#FF9800"
                                   VerticalOptions="Center"/>
                        </HorizontalStackLayout>

                        <!-- Текстовый ответ -->
                        <Border x:Name="TextAnswerFrame"
                                IsVisible="False"
                                BackgroundColor="#F8F9FA"
                                Stroke="#E0E0E0"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 8"
                                Padding="15">
                            <Label x:Name="TextAnswerLabel" 
                                   FontSize="15"
                                   TextColor="#333"
                                   LineBreakMode="WordWrap"/>
                        </Border>

                        <!-- Файл ответа -->
                        <Border x:Name="FileAnswerFrame"
                                IsVisible="False"
                                BackgroundColor="#F8F9FA"
                                Stroke="#E0E0E0"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 8"
                                Padding="15">
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                <Label Grid.Column="0"
                                       x:Name="FileIconLabel"
                                       Text="📎"
                                       FontSize="32"
                                       TextColor="#FF9800"
                                       VerticalOptions="Center"/>
                                <VerticalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">
                                    <Label x:Name="FileNameLabel" 
                                           FontSize="15" 
                                           FontAttributes="Bold"
                                           TextColor="#333"
                                           LineBreakMode="TailTruncation"/>
                                    <Label x:Name="FileSizeLabel" 
                                           FontSize="13" 
                                           TextColor="Gray"/>
                                </VerticalStackLayout>
                                <Button Grid.Column="2"
                                        Text="📥"
                                        FontSize="20"
                                        WidthRequest="44"
                                        HeightRequest="44"
                                        CornerRadius="22"
                                        BackgroundColor="#FF9800"
                                        TextColor="White"
                                        Clicked="OnDownloadFileClicked"
                                        VerticalOptions="Center"/>
                            </Grid>
                        </Border>
                    </VerticalStackLayout>
                </Border>

                <!-- Блок оценивания -->
                <Border BackgroundColor="White"
                        Stroke="{DynamicResource SuccessColor}"
                        StrokeThickness="2"
                        StrokeShape="RoundRectangle 12"
                        Padding="20">
                    <VerticalStackLayout Spacing="20">
                        <HorizontalStackLayout Spacing="10">
                            <Label Text="⭐"
                                   FontSize="28"
                                   VerticalOptions="Center"/>
                            <Label Text="Оценивание"
                                   FontSize="20"
                                   FontAttributes="Bold"
                                   TextColor="{DynamicResource SuccessColor}"
                                   VerticalOptions="Center"/>
                        </HorizontalStackLayout>

                        <!-- Оценка -->
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Оценка (0-100)"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="#666"/>

                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="15">
                                <Border Grid.Column="0"
                                        BackgroundColor="#F8F9FA"
                                        Stroke="#E0E0E0"
                                        StrokeThickness="1"
                                        StrokeShape="RoundRectangle 8"
                                        Padding="0">
                                    <Entry x:Name="ScoreEntry" 
                                           Placeholder="Введите баллы"
                                           Keyboard="Numeric"
                                           BackgroundColor="Transparent"
                                           Margin="15,0"
                                           FontSize="15"
                                           HeightRequest="50"/>
                                </Border>

                                <Border Grid.Column="1"
                                        BackgroundColor="{DynamicResource SuccessColor}"
                                        Padding="15,0"
                                        StrokeShape="RoundRectangle 8">
                                    <Label Text="/ 100"
                                           FontSize="15"
                                           FontAttributes="Bold"
                                           TextColor="White"
                                           VerticalOptions="Center"/>
                                </Border>
                            </Grid>

                            <!-- Слайдер -->
                            <Slider x:Name="ScoreSlider"
                                    Minimum="0"
                                    Maximum="100"
                                    Value="0"
                                    MinimumTrackColor="{DynamicResource SuccessColor}"
                                    MaximumTrackColor="#E0E0E0"
                                    ThumbColor="{DynamicResource SuccessColor}"
                                    HeightRequest="40"/>
                        </VerticalStackLayout>

                        <!-- Комментарий -->
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Комментарий преподавателя"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="#666"/>

                            <Border BackgroundColor="#F8F9FA"
                                    Stroke="#E0E0E0"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 8"
                                    Padding="0">
                                <Editor x:Name="CommentEditor" 
                                        HeightRequest="120"
                                        Placeholder="Напишите комментарий к работе..."
                                        BackgroundColor="Transparent"
                                        Margin="15,10"
                                        FontSize="14"
                                        TextColor="#333"/>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Кнопки -->
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="15">
                            <Button Grid.Column="0"
                                    Text="Отмена"
                                    Clicked="OnBackClicked"
                                    BackgroundColor="#6C757D"
                                    TextColor="White"
                                    CornerRadius="8"
                                    HeightRequest="50"
                                    FontSize="15"/>

                            <Button Grid.Column="1"
                                    Text=" Сохранить оценку"
                                    Clicked="OnSaveGradeClicked"
                                    BackgroundColor="{DynamicResource SuccessColor}"
                                    TextColor="DarkCyan"
                                    CornerRadius="8"
                                    HeightRequest="50"
                                    FontSize="15"
                                    FontAttributes="Bold"/>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- История оценки (если работа уже оценивалась) -->
                <Border x:Name="GradingHistorySection"
                        IsVisible="False"
                        BackgroundColor="#E8F5E8"
                        Stroke="#4CAF50"
                        StrokeThickness="2"
                        StrokeShape="RoundRectangle 12"
                        Padding="20">
                    <VerticalStackLayout Spacing="12">
                        <HorizontalStackLayout Spacing="10">
                            <Label Text="📊"
                                   FontSize="28"
                                   VerticalOptions="Center"/>
                            <Label Text="Предыдущая оценка"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="#4CAF50"
                                   VerticalOptions="Center"/>
                        </HorizontalStackLayout>

                        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto" RowSpacing="8" ColumnSpacing="15">
                            <Label Grid.Row="0" Grid.Column="0"
                                   Text="Оценка:"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="#666"/>
                            <Label Grid.Row="0" Grid.Column="1"
                                   x:Name="PreviousScoreLabel"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   TextColor="#4CAF50"/>

                            <Label Grid.Row="1" Grid.Column="0"
                                   Text="Проверил:"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="#666"/>
                            <Label Grid.Row="1" Grid.Column="1"
                                   x:Name="GradedByLabel"
                                   FontSize="14"
                                   TextColor="#666"/>
                        </Grid>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>