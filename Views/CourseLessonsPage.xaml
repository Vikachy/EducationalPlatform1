<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:EducationalPlatform.Converters"
             x:Class="EducationalPlatform.Views.CourseLessonsPage"
             Title="Уроки курса"
             BackgroundColor="{DynamicResource BackgroundColor}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:StatusColorConverter x:Key="StatusToColorConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*">
        <!-- Заголовок -->
        <Border Grid.Row="0"
                BackgroundColor="{DynamicResource PrimaryColor}"
                Padding="20,15"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 0,0,0,20">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Button Grid.Column="0"
                        Text="←"
                        Clicked="OnBackClicked"
                        BackgroundColor="Transparent"
                        TextColor="White"
                        FontSize="20"
                        WidthRequest="40"
                        HeightRequest="40" />
                <Label Grid.Column="1"
                       x:Name="CourseTitleLabel"
                       Text="Уроки курса" 
                       FontSize="20" 
                       FontAttributes="Bold" 
                       TextColor="White" 
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />
                <Button Grid.Column="2"
                        Text="+"
                        Clicked="OnAddLessonClicked"
                        BackgroundColor="White"
                        TextColor="{DynamicResource PrimaryColor}"
                        FontSize="20"
                        WidthRequest="40"
                        HeightRequest="40"
                        CornerRadius="20" />
            </Grid>
        </Border>

        <Grid Grid.Row="1" RowDefinitions="Auto,Auto,*">
            <!-- Статистика -->
            <Grid Grid.Row="0" ColumnDefinitions="*,*,*" ColumnSpacing="10" Margin="20,20,20,10">
                <Border Grid.Column="0"
                        BackgroundColor="#E3F2FD"
                        Padding="15"
                        StrokeShape="RoundRectangle 10">
                    <VerticalStackLayout>
                        <Label Text="Всего уроков" FontSize="11" TextColor="#1976D2"/>
                        <Label x:Name="TotalLessonsLabel" Text="0" FontSize="18" FontAttributes="Bold" TextColor="#1976D2"/>
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Column="1"
                        BackgroundColor="#E8F5E8"
                        Padding="15"
                        StrokeShape="RoundRectangle 10">
                    <VerticalStackLayout>
                        <Label Text="Теория" FontSize="11" TextColor="#4CAF50"/>
                        <Label x:Name="TheoryCountLabel" Text="0" FontSize="18" FontAttributes="Bold" TextColor="#4CAF50"/>
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Column="2"
                        BackgroundColor="#FFF3E0"
                        Padding="15"
                        StrokeShape="RoundRectangle 10">
                    <VerticalStackLayout>
                        <Label Text="Практика" FontSize="11" TextColor="#FF9800"/>
                        <Label x:Name="PracticeCountLabel" Text="0" FontSize="18" FontAttributes="Bold" TextColor="#FF9800"/>
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <!-- Информация о курсе -->
            <Border Grid.Row="1"
                    BackgroundColor="White"
                    Margin="20,10,20,10"
                    Padding="15"
                    Stroke="#E0E0E0"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 12">
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="15">
                    <Border Grid.Column="0"
                            BackgroundColor="{DynamicResource PrimaryColor}"
                            WidthRequest="40"
                            HeightRequest="40"
                            StrokeShape="RoundRectangle 8">
                        <Label Text="📚"
                               FontSize="20"
                               TextColor="White"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Border>
                    <VerticalStackLayout Grid.Column="1">
                        <Label x:Name="CourseNameLabel"
                               Text="Название курса"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="#333"/>
                        <Label x:Name="CourseInfoLabel"
                               Text="Загрузка информации..."
                               FontSize="12"
                               TextColor="#666"/>
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <!-- Список уроков -->
            <CollectionView Grid.Row="2"
                          x:Name="LessonsCollectionView"
                          Margin="20,0,20,20"
                          ItemsSource="{Binding Lessons}"
                          EmptyView="В этом курсе нет уроков">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,5"
                                BackgroundColor="White"
                                Stroke="#E0E0E0"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 12"
                                Padding="15">
                            <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="8">
                                <!-- Заголовок с названием и типом -->
                                <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                                    <Border Grid.Column="0"
                                            BackgroundColor="{Binding LessonType, Converter={StaticResource LessonTypeToColorConverter}}"
                                            WidthRequest="40"
                                            HeightRequest="40"
                                            StrokeShape="RoundRectangle 8">
                                        <Label Text="{Binding LessonType, Converter={StaticResource LessonTypeToIconConverter}}"
                                               FontSize="20"
                                               TextColor="White"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center"/>
                                    </Border>

                                    <Label Grid.Column="1"
                                           Text="{Binding Title}"
                                           FontSize="16"
                                           FontAttributes="Bold"
                                           TextColor="#333"
                                           VerticalOptions="Center"/>

                                    <Border Grid.Column="2"
                                            BackgroundColor="{Binding IsActive, Converter={StaticResource StatusToColorConverter}}"
                                            Padding="6,3"
                                            StrokeShape="RoundRectangle 3">
                                        <Label Text="{Binding IsActive, Converter={StaticResource ActiveStatusTextConverter}}"
                                               TextColor="White"
                                               FontSize="9"
                                               FontAttributes="Bold"/>
                                    </Border>
                                </Grid>

                                <!-- Тип урока -->
                                <Label Grid.Row="1"
                                       Text="{Binding LessonTypeDisplay}"
                                       FontSize="12"
                                       TextColor="{Binding LessonType, Converter={StaticResource LessonTypeToColorConverter}}"
                                       FontAttributes="Bold"/>

                                <!-- Краткое содержание (если есть) -->
                                <Label Grid.Row="2"
                                       Text="{Binding ContentPreview}"
                                       FontSize="13"
                                       TextColor="#666"
                                       MaxLines="2"
                                       LineBreakMode="TailTruncation"/>

                                <!-- Кнопки действий -->
                                <Grid Grid.Row="3" ColumnDefinitions="*,*,*,*" ColumnSpacing="5">
                                    <Button Grid.Column="0"
                                            Text="👁️ Просмотр"
                                            Clicked="OnViewLessonClicked"
                                            CommandParameter="{Binding .}"
                                            BackgroundColor="#2196F3"
                                            TextColor="White"
                                            HeightRequest="35"
                                            CornerRadius="8"
                                            FontSize="10"/>
                                    <Button Grid.Column="1"
                                            Text="✏️ Редактировать"
                                            Clicked="OnEditLessonClicked"
                                            CommandParameter="{Binding .}"
                                            BackgroundColor="#FFC107"
                                            TextColor="White"
                                            HeightRequest="35"
                                            CornerRadius="8"
                                            FontSize="10"/>
                                    <Button Grid.Column="2"
                                            Text="📊 Статистика"
                                            Clicked="OnLessonStatsClicked"
                                            CommandParameter="{Binding .}"
                                            BackgroundColor="#4CAF50"
                                            TextColor="White"
                                            HeightRequest="35"
                                            CornerRadius="8"
                                            FontSize="10"/>
                                    <Button Grid.Column="3"
                                            Text="🗑️ Удалить"
                                            Clicked="OnDeleteLessonClicked"
                                            CommandParameter="{Binding .}"
                                            BackgroundColor="#F44336"
                                            TextColor="White"
                                            HeightRequest="35"
                                            CornerRadius="8"
                                            FontSize="10"/>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>
    </Grid>
</ContentPage>