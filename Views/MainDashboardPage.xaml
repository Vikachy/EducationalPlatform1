<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="EducationalPlatform.Views.MainDashboardPage"
    Title="Главная"
    BackgroundColor="{DynamicResource BackgroundColor}">

    <Grid RowDefinitions="Auto,*">
        <!-- ШАПКА С АНИМАЦИЕЙ -->
        <Border Grid.Row="0"
                BackgroundColor="{DynamicResource PrimaryColor}"
                Stroke="{DynamicResource SecondaryColor}"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 0,0,0,20"
                Padding="0">
            <Grid ColumnDefinitions="{OnIdiom Default='Auto,*,Auto,Auto,Auto', Desktop='Auto,*,Auto,Auto,Auto'}"
                  Padding="{OnIdiom Default='10,10', Desktop='20,15'}"
                  VerticalOptions="Center"
                  ColumnSpacing="{OnIdiom Default='5', Desktop='10'}">

                <!-- АВАТАР -->
                <Border Grid.Column="0"
                        x:Name="AvatarFrameBorder"
                        BackgroundColor="White"
                        Stroke="{DynamicResource AccentColor}"
                        StrokeThickness="2"
                        StrokeShape="RoundRectangle 25"
                        WidthRequest="{OnIdiom Default='45', Desktop='50'}"
                        HeightRequest="{OnIdiom Default='45', Desktop='50'}"
                        VerticalOptions="Center">
                    <Image x:Name="AvatarImage"
                           Source="default_avatar.png"
                           Aspect="AspectFill"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           WidthRequest="{OnIdiom Default='41', Desktop='46'}"
                           HeightRequest="{OnIdiom Default='41', Desktop='46'}" />
                </Border>

                <!-- ПРИВЕТСТВИЕ С ЭМОДЗИ -->
                <VerticalStackLayout Grid.Column="1"
                                    Spacing="{OnIdiom Default='1', Desktop='2'}"
                                    Padding="{OnIdiom Default='8,0', Desktop='15,0'}"
                                    VerticalOptions="Center">
                    <HorizontalStackLayout Spacing="5">
                        <Label x:Name="WelcomeLabel"
                               Text="Добро пожаловать!"
                               FontSize="{OnIdiom Default='13', Desktop='16'}"
                               TextColor="White"
                               FontAttributes="Bold"
                               LineBreakMode="TailTruncation" />
                        <Label x:Name="UserEmojiLabel"
                               FontSize="{OnIdiom Default='13', Desktop='16'}"
                               TextColor="White"
                               IsVisible="False" />
                    </HorizontalStackLayout>
                    <Label x:Name="StatsLabel"
                           Text="Серия: 0 дней 🔥 | Валюта: 0"
                           FontSize="{OnIdiom Default='9', Desktop='12'}"
                           TextColor="White"
                           LineBreakMode="TailTruncation" />
                </VerticalStackLayout>

                <!-- КНОПКА НАСТРОЕК -->
                <Button Grid.Column="2"
                        Text="⚙️"
                        Clicked="OnSettingsClicked"
                        BackgroundColor="Transparent"
                        TextColor="White"
                        FontSize="{OnIdiom Default='16', Desktop='18'}"
                        WidthRequest="{OnIdiom Default='38', Desktop='45'}"
                        HeightRequest="{OnIdiom Default='38', Desktop='45'}"
                        CornerRadius="19"
                        Padding="0" />

                <!-- КНОПКА ПРОФИЛЯ -->
                <Button Grid.Column="3"
                        Text="👤"
                        Clicked="OnProfileClicked"
                        BackgroundColor="Transparent"
                        TextColor="White"
                        FontSize="{OnIdiom Default='16', Desktop='20'}"
                        WidthRequest="{OnIdiom Default='38', Desktop='45'}"
                        HeightRequest="{OnIdiom Default='38', Desktop='45'}"
                        CornerRadius="19"
                        Padding="0" />

                <!-- КНОПКА ВЫХОДА -->
                <Button Grid.Column="4"
                        Text="⎋"
                        Clicked="OnLogoutClicked"
                        BackgroundColor="Transparent"
                        TextColor="White"
                        FontSize="{OnIdiom Default='14', Desktop='18'}"
                        WidthRequest="{OnIdiom Default='38', Desktop='45'}"
                        HeightRequest="{OnIdiom Default='38', Desktop='45'}"
                        CornerRadius="19"
                        Padding="0" />
            </Grid>
        </Border>

        <!-- ОСНОВНОЙ КОНТЕНТ -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="20" Padding="20">

                <!-- МОИ АКТИВНЫЕ КУРСЫ -->
                <Border BackgroundColor="{DynamicResource BackgroundColor}"
                        Stroke="{DynamicResource PrimaryColor}"
                        StrokeThickness="2"
                        StrokeShape="RoundRectangle 15"
                        Padding="0">
                    <VerticalStackLayout Spacing="0">
                        <Border BackgroundColor="{DynamicResource PrimaryColor}"
                                StrokeThickness="0"
                                Padding="20,15">
                            <VerticalStackLayout Spacing="10">
                                <Label x:Name="MyCoursesLabel"
                                       Text="Мои активные курсы"
                                       FontSize="{OnIdiom Default='16', Desktop='18'}"
                                       TextColor="White"
                                       FontAttributes="Bold"
                                       VerticalOptions="Center" />
                                <HorizontalStackLayout Spacing="10">
                                    <Button Text="Мои курсы →"
                                            Clicked="OnMyCoursesClicked"
                                            BackgroundColor="Transparent"
                                            TextColor="White"
                                            BorderColor="White"
                                            BorderWidth="1"
                                            HeightRequest="{OnIdiom Default='30', Desktop='35'}"
                                            CornerRadius="15"
                                            FontSize="{OnIdiom Default='11', Desktop='14'}" />
                                    <Button Text="Все курсы →"
                                            Clicked="OnAllCoursesClicked"
                                            BackgroundColor="Transparent"
                                            TextColor="White"
                                            BorderColor="White"
                                            BorderWidth="1"
                                            HeightRequest="{OnIdiom Default='30', Desktop='35'}"
                                            CornerRadius="15"
                                            FontSize="{OnIdiom Default='11', Desktop='14'}" />
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                        </Border>

                        <CollectionView x:Name="MyCoursesCollectionView"
                                      HeightRequest="180"
                                      SelectionMode="Single"
                                      SelectionChanged="OnMyCourseSelected">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="15,10"
                                            BackgroundColor="#F8F9FA"
                                            Stroke="{DynamicResource PrimaryColor}"
                                            StrokeThickness="1"
                                            StrokeShape="RoundRectangle 10"
                                            Padding="15">
                                        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" 
                                              RowSpacing="5" ColumnSpacing="10">
                                            <Label Grid.Row="0" Grid.Column="0"
                                                   Text="{Binding CourseName}"
                                                   FontSize="16"
                                                   FontAttributes="Bold"
                                                   TextColor="{DynamicResource TextColor}" />
                                            <Label Grid.Row="0" Grid.Column="1"
                                                   Text="{Binding Progress, StringFormat='{0}%'}"
                                                   FontSize="14"
                                                   TextColor="{DynamicResource PrimaryColor}"
                                                   FontAttributes="Bold" />

                                            <ProgressBar Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                                         Progress="{Binding ProgressDecimal}"
                                                         ProgressColor="{DynamicResource PrimaryColor}"
                                                         BackgroundColor="#E0E0E0"
                                                         HeightRequest="8"
                                                         VerticalOptions="Center" />

                                            <HorizontalStackLayout Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                                                  Spacing="10">
                                                <Label Text="{Binding Language}"
                                                       FontSize="10"
                                                       BackgroundColor="{DynamicResource SecondaryColor}"
                                                       TextColor="White"
                                                       Padding="5,2" />
                                                <Label Text="{Binding Difficulty}"
                                                       FontSize="10"
                                                       BackgroundColor="{DynamicResource AccentColor}"
                                                       TextColor="White"
                                                       Padding="5,2" />
                                                <Label Text="{Binding TimeLeft}"
                                                       FontSize="10"
                                                       BackgroundColor="#666"
                                                       TextColor="White"
                                                       Padding="5,2" />
                                            </HorizontalStackLayout>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>

                <Label x:Name="QuickActionsLabel"
                       Text="Быстрый доступ"
                       FontSize="20"
                       TextColor="{DynamicResource TextColor}"
                       FontAttributes="Bold" />

                <Grid ColumnDefinitions="{OnIdiom Default='*,*', Desktop='*,*'}"
                      RowDefinitions="{OnIdiom Default='Auto,Auto', Desktop='Auto,Auto'}"
                      ColumnSpacing="{OnIdiom Default='10', Desktop='15'}"
                      RowSpacing="{OnIdiom Default='10', Desktop='15'}">

                    <!-- КУРСЫ -->
                    <Border Grid.Row="0" Grid.Column="0"
                            BackgroundColor="{DynamicResource BackgroundColor}"
                            Stroke="{DynamicResource PrimaryColor}"
                            StrokeThickness="2"
                            StrokeShape="RoundRectangle 15">
                        <VerticalStackLayout Spacing="12" Padding="{OnIdiom Default='15', Desktop='20'}">
                            <Label Text="📚"
                                   FontSize="{OnIdiom Default='24', Desktop='28'}"
                                   HorizontalOptions="Center" />
                            <Label Text="Все курсы"
                                   FontSize="{OnIdiom Default='14', Desktop='16'}"
                                   FontAttributes="Bold"
                                   HorizontalOptions="Center"
                                   TextColor="{DynamicResource TextColor}" />
                            <Button Text="Изучать →"
                                    Clicked="OnCoursesClicked"
                                    BackgroundColor="{DynamicResource PrimaryColor}"
                                    TextColor="White"
                                    HeightRequest="{OnIdiom Default='35', Desktop='40'}"
                                    CornerRadius="20"
                                    FontSize="{OnIdiom Default='12', Desktop='14'}"
                                    FontAttributes="Bold" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- ПРОГРЕСС -->
                    <Border Grid.Row="0" Grid.Column="1"
                            BackgroundColor="{DynamicResource BackgroundColor}"
                            Stroke="{DynamicResource PrimaryColor}"
                            StrokeThickness="2"
                            StrokeShape="RoundRectangle 15">
                        <VerticalStackLayout Spacing="12" Padding="{OnIdiom Default='15', Desktop='20'}">
                            <Label Text="📊"
                                   FontSize="{OnIdiom Default='24', Desktop='28'}"
                                   HorizontalOptions="Center" />
                            <Label Text="Прогресс"
                                   FontSize="{OnIdiom Default='14', Desktop='16'}"
                                   FontAttributes="Bold"
                                   HorizontalOptions="Center"
                                   TextColor="{DynamicResource TextColor}" />
                            <Button Text="Смотреть →"
                                    Clicked="OnProgressClicked"
                                    BackgroundColor="{DynamicResource PrimaryColor}"
                                    TextColor="White"
                                    HeightRequest="{OnIdiom Default='35', Desktop='40'}"
                                    CornerRadius="20"
                                    FontSize="{OnIdiom Default='12', Desktop='14'}"
                                    FontAttributes="Bold" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- ДОСТИЖЕНИЯ -->
                    <Border Grid.Row="1" Grid.Column="0"
                            BackgroundColor="{DynamicResource BackgroundColor}"
                            Stroke="{DynamicResource AccentColor}"
                            StrokeThickness="2"
                            StrokeShape="RoundRectangle 15">
                        <VerticalStackLayout Spacing="12" Padding="{OnIdiom Default='15', Desktop='20'}">
                            <Label Text="🏆"
                                   FontSize="{OnIdiom Default='24', Desktop='28'}"
                                   HorizontalOptions="Center" />
                            <Label Text="Достижения"
                                   FontSize="{OnIdiom Default='14', Desktop='16'}"
                                   FontAttributes="Bold"
                                   HorizontalOptions="Center"
                                   TextColor="{DynamicResource TextColor}" />
                            <Button Text="Мои награды →"
                                    Clicked="OnAchievementsClicked"
                                    BackgroundColor="{DynamicResource AccentColor}"
                                    TextColor="White"
                                    HeightRequest="{OnIdiom Default='35', Desktop='40'}"
                                    CornerRadius="20"
                                    FontSize="{OnIdiom Default='12', Desktop='14'}"
                                    FontAttributes="Bold" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- МАГАЗИН -->
                    <Border Grid.Row="1" Grid.Column="1"
                            BackgroundColor="{DynamicResource BackgroundColor}"
                            Stroke="{DynamicResource SecondaryColor}"
                            StrokeThickness="2"
                            StrokeShape="RoundRectangle 15">
                        <VerticalStackLayout Spacing="12" Padding="{OnIdiom Default='15', Desktop='20'}">
                            <Label Text="🛒"
                                   FontSize="{OnIdiom Default='24', Desktop='28'}"
                                   HorizontalOptions="Center" />
                            <Label Text="Магазин"
                                   FontSize="{OnIdiom Default='14', Desktop='16'}"
                                   FontAttributes="Bold"
                                   HorizontalOptions="Center"
                                   TextColor="{DynamicResource TextColor}" />
                            <Button Text="Покупать →"
                                    Clicked="OnShopClicked"
                                    BackgroundColor="{DynamicResource SecondaryColor}"
                                    TextColor="White"
                                    HeightRequest="{OnIdiom Default='35', Desktop='40'}"
                                    CornerRadius="20"
                                    FontSize="{OnIdiom Default='12', Desktop='14'}"
                                    FontAttributes="Bold" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- СЕГОДНЯШНИЕ ЗАДАЧИ -->
                <Border BackgroundColor="{DynamicResource BackgroundColor}"
                        Stroke="#4CAF50"
                        StrokeThickness="2"
                        StrokeShape="RoundRectangle 15"
                        Padding="0">
                    <VerticalStackLayout Spacing="0">
                        <Border BackgroundColor="#4CAF50"
                                StrokeThickness="0"
                                Padding="20,15">
                            <HorizontalStackLayout>
                                <Label x:Name="TodayTasksLabel"
                                       Text="Сегодняшние задачи"
                                       FontSize="18"
                                       TextColor="White"
                                       FontAttributes="Bold"
                                       VerticalOptions="Center" />
                                <Label x:Name="TodayTasksCountLabel"
                                       Text="0/2 завершено"
                                       FontSize="14"
                                       TextColor="White"
                                       Margin="20,0,0,0"
                                       VerticalOptions="Center" />
                            </HorizontalStackLayout>
                        </Border>

                        <CollectionView x:Name="TodayTasksCollectionView"
                                      HeightRequest="150"
                                      SelectionMode="None">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="15,8"
                                            BackgroundColor="{Binding CardColor}"
                                            Stroke="{Binding BorderColor}"
                                            StrokeThickness="1"
                                            StrokeShape="RoundRectangle 8"
                                            Padding="12">
                                        <Grid ColumnDefinitions="Auto,*,Auto" VerticalOptions="Center">
                                            <Label Grid.Column="0"
                                                   Text="{Binding Icon}"
                                                   FontSize="16"
                                                   VerticalOptions="Center" />
                                            <VerticalStackLayout Grid.Column="1" Spacing="2" Margin="10,0">
                                                <Label Text="{Binding Title}"
                                                       FontSize="14"
                                                       FontAttributes="Bold"
                                                       TextColor="{DynamicResource TextColor}" />
                                                <Label Text="{Binding Description}"
                                                       FontSize="11"
                                                       TextColor="#666" />
                                            </VerticalStackLayout>
                                            <Button Grid.Column="2"
                                                    Text="{Binding ButtonText}"
                                                    Clicked="OnTaskButtonClicked"
                                                    BackgroundColor="{Binding ButtonColor}"
                                                    TextColor="White"
                                                    HeightRequest="30"
                                                    CornerRadius="15"
                                                    FontSize="10"
                                                    CommandParameter="{Binding .}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>

                <!-- ПАНЕЛЬ УЧИТЕЛЯ -->
                <!-- ПАНЕЛЬ УЧИТЕЛЯ -->
                <Border x:Name="TeacherPanel"
        BackgroundColor="{DynamicResource BackgroundColor}"
        Stroke="{DynamicResource AccentColor}"
        StrokeThickness="2"
        StrokeShape="RoundRectangle 15"
        IsVisible="False"
        Padding="20">
                    <VerticalStackLayout Spacing="15">
                        <Label Text="Панель преподавателя"
               FontSize="18"
               FontAttributes="Bold"
               TextColor="{DynamicResource AccentColor}"
               HorizontalOptions="Center" />

                        <!-- Кнопка для контент-менеджера -->
                        <Button x:Name="ContentManagerButton"
                Text="📰 Управление контентом" 
                Clicked="OnContentManagerClicked"
                BackgroundColor="#FF9800"
                TextColor="White"
                HeightRequest="40"
                CornerRadius="20"
                IsVisible="{Binding IsContentManager}" />

                        <Button Text="Управление контентом" 
                Clicked="OnManageCourseContentClicked"
                BackgroundColor="{DynamicResource PrimaryColor}"
                TextColor="White"
                HeightRequest="40"
                CornerRadius="20" />

                        <Button Text="Управление курсами"
                Clicked="OnTeacherManagementClicked"
                BackgroundColor="{DynamicResource AccentColor}"
                TextColor="White"
                HeightRequest="40"
                CornerRadius="20" />

                        <Button Text="Учебные группы"
                Clicked="OnTeacherGroupsClicked"
                BackgroundColor="{DynamicResource PrimaryColor}"
                TextColor="White"
                HeightRequest="40"
                CornerRadius="20" />

                        <VerticalStackLayout Spacing="10" x:Name="TeacherButtonsLayout" IsVisible="False">
                            <Button Text="Создать тест" 
                    Clicked="OnCreateTestClicked"
                    BackgroundColor="{DynamicResource SecondaryColor}"
                    TextColor="White"
                    HeightRequest="35"
                    CornerRadius="15"/>
                            <Button Text="Создать практику" 
                    Clicked="OnCreatePracticeClicked"
                    BackgroundColor="{DynamicResource SecondaryColor}"
                    TextColor="White"
                    HeightRequest="35"
                    CornerRadius="15"/>
                            <Button Text="Создать теорию" 
                    Clicked="OnCreateTheoryClicked"
                    BackgroundColor="{DynamicResource SecondaryColor}"
                    TextColor="White"
                    HeightRequest="35"
                    CornerRadius="15"/>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <!-- ЛЕНТА НОВОСТЕЙ -->
                <Border BackgroundColor="{DynamicResource BackgroundColor}"
                        Stroke="{DynamicResource PrimaryColor}"
                        StrokeThickness="2"
                        StrokeShape="RoundRectangle 15"
                        Padding="0">
                    <VerticalStackLayout Spacing="0">
                        <Border BackgroundColor="{DynamicResource PrimaryColor}"
                                StrokeThickness="0"
                                Padding="{OnIdiom Default='15,12', Desktop='20,15'}">
                            <Grid ColumnDefinitions="{OnIdiom Default='*,Auto', Desktop='*,Auto'}"
                                  ColumnSpacing="{OnIdiom Default='10', Desktop='20'}">
                                <Label Grid.Column="0"
                                       x:Name="NewsLabel"
                                       Text="Последние новости"
                                       FontSize="{OnIdiom Default='16', Desktop='18'}"
                                       TextColor="White"
                                       FontAttributes="Bold"
                                       VerticalOptions="Center" />
                                <Button Grid.Column="1"
                                        Text="{OnIdiom Default='→', Desktop='Все новости →'}"
                                        Clicked="OnAllNewsClicked"
                                        BackgroundColor="Transparent"
                                        TextColor="White"
                                        BorderColor="White"
                                        BorderWidth="1"
                                        HeightRequest="{OnIdiom Default='32', Desktop='35'}"
                                        WidthRequest="{OnIdiom Default='40', Desktop='Auto'}"
                                        CornerRadius="15"
                                        FontSize="{OnIdiom Default='16', Desktop='14'}"
                                        Padding="{OnIdiom Default='8,0', Desktop='12,0'}" />
                            </Grid>
                        </Border>
                        <CollectionView x:Name="NewsCollectionView"
                                      HeightRequest="200"
                                      SelectionMode="None">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="15,10"
                                            BackgroundColor="#F8F9FA"
                                            Stroke="#E0E0E0"
                                            StrokeThickness="1"
                                            StrokeShape="RoundRectangle 10"
                                            Padding="15">
                                        <VerticalStackLayout Spacing="8">
                                            <Label Text="{Binding Title}"
                                                   FontSize="16"
                                                   FontAttributes="Bold"
                                                   TextColor="{DynamicResource TextColor}" />
                                            <Label Text="{Binding Content}"
                                                   FontSize="13"
                                                   TextColor="#666"
                                                   MaxLines="2" />
                                            <Label Text="{Binding PublishedDate, StringFormat='📅 {0:dd.MM.yyyy}'}"
                                                   FontSize="11"
                                                   TextColor="#999" />
                                        </VerticalStackLayout>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>

                <!-- ДОПОЛНИТЕЛЬНЫЕ ФУНКЦИИ -->
                <Border BackgroundColor="{DynamicResource BackgroundColor}"
                        Stroke="{DynamicResource PrimaryColor}"
                        StrokeThickness="2"
                        StrokeShape="RoundRectangle 15"
                        Padding="20">
                    <VerticalStackLayout Spacing="15">
                        <Label Text="Дополнительные функции"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="{DynamicResource PrimaryColor}"
                               HorizontalOptions="Center" />

                        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="10">
                            <Button Grid.Row="0" Grid.Column="0"
                                    Text="Конкурсы"
                                    Clicked="OnContestsClicked"
                                    BackgroundColor="#FF9800"
                                    TextColor="White"
                                    HeightRequest="50"
                                    CornerRadius="25" />
                            <Button Grid.Row="0" Grid.Column="1"
                                    Text="Новости"
                                    Clicked="OnNewsClicked"
                                    BackgroundColor="#4CAF50"
                                    TextColor="White"
                                    HeightRequest="50"
                                    CornerRadius="25" />
                            <Button Grid.Row="1" Grid.Column="0"
                                    Text="Чат"
                                    Clicked="OnChatClicked"
                                    BackgroundColor="#9C27B0"
                                    TextColor="White"
                                    HeightRequest="50"
                                    CornerRadius="25" />
                            <Button Grid.Row="1" Grid.Column="1"
                                    Text="Поддержка"
                                    Clicked="OnSupportClicked"
                                    BackgroundColor="#F44336"
                                    TextColor="White"
                                    HeightRequest="50"
                                    CornerRadius="25" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>