<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:EducationalPlatform.Converters"
             x:Class="EducationalPlatform.Views.AdminSettingsPage"
             Title="Системные настройки"
             BackgroundColor="{DynamicResource BackgroundColor}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:BoolToColorConverter x:Key="BoolToColorConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*">
        <!-- Заголовок -->
        <Border Grid.Row="0"
                BackgroundColor="{DynamicResource PrimaryColor}"
                Padding="20,15"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 0,0,0,20">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Button Grid.Column="0"
                        Text="←"
                        Clicked="OnBackClicked"
                        BackgroundColor="Transparent"
                        TextColor="White"
                        FontSize="20"
                        WidthRequest="40"
                        HeightRequest="40" />
                <Label Grid.Column="1"
                       Text="Системные настройки" 
                       FontSize="20" 
                       FontAttributes="Bold" 
                       TextColor="White" 
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />
                <Button Grid.Column="2"
                        Text="Сохранить"
                        Clicked="OnSaveClicked"
                        BackgroundColor="White"
                        TextColor="{DynamicResource PrimaryColor}"
                        FontSize="14"
                        Padding="15,8"
                        CornerRadius="20" />
            </Grid>
        </Border>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20" Spacing="20">

                <!-- Основные настройки -->
                <Border BackgroundColor="White"
                        Stroke="{DynamicResource PrimaryColor}"
                        StrokeThickness="2"
                        StrokeShape="RoundRectangle 12"
                        Padding="20">
                    <VerticalStackLayout Spacing="15">
                        <Label Text="Основные"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="{DynamicResource PrimaryColor}"/>

                        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="15" ColumnSpacing="15">
                            <Label Grid.Row="0" Grid.Column="0"
                                   Text="Название:"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="#666"
                                   VerticalOptions="Center"/>
                            <Border Grid.Row="0" Grid.Column="1"
                                    BackgroundColor="#F8F9FA"
                                    Stroke="#E0E0E0"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 8"
                                    Padding="0">
                                <Entry x:Name="PlatformNameEntry"
                                       Text="Educational Platform"
                                       BackgroundColor="Transparent"
                                       Margin="15,0"
                                       FontSize="14"
                                       HeightRequest="45"/>
                            </Border>

                            <Label Grid.Row="1" Grid.Column="0"
                                   Text="Email поддержки:"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="#666"
                                   VerticalOptions="Center"/>
                            <Border Grid.Row="1" Grid.Column="1"
                                    BackgroundColor="#F8F9FA"
                                    Stroke="#E0E0E0"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 8"
                                    Padding="0">
                                <Entry x:Name="SupportEmailEntry"
                                       Text="support@eduplatform.com"
                                       Keyboard="Email"
                                       BackgroundColor="Transparent"
                                       Margin="15,0"
                                       FontSize="14"
                                       HeightRequest="45"/>
                            </Border>

                            <Label Grid.Row="2" Grid.Column="0"
                                   Text="Регистрация:"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="#666"
                                   VerticalOptions="Center"/>
                            <Grid Grid.Row="2" Grid.Column="1">
                                <Switch x:Name="AllowRegistrationSwitch"
                                        IsToggled="True"
                                        OnColor="{DynamicResource SuccessColor}"
                                        ThumbColor="White"
                                        VerticalOptions="Center"/>
                            </Grid>

                            <Label Grid.Row="3" Grid.Column="0"
                                   Text="Тема по умолчанию:"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="#666"
                                   VerticalOptions="Center"/>
                            <Border Grid.Row="3" Grid.Column="1"
                                    BackgroundColor="#F8F9FA"
                                    Stroke="#E0E0E0"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 8"
                                    Padding="0">
                                <Picker x:Name="DefaultThemePicker"
                                        BackgroundColor="Transparent"
                                        Margin="15,0"
                                        FontSize="14"
                                        HeightRequest="45">
                                    <Picker.Items>
                                        <x:String>Светлая</x:String>
                                        <x:String>Темная</x:String>
                                        <x:String>Системная</x:String>
                                    </Picker.Items>
                                </Picker>
                            </Border>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Настройки валюты -->
                <Border BackgroundColor="White"
                        Stroke="#4CAF50"
                        StrokeThickness="2"
                        StrokeShape="RoundRectangle 12"
                        Padding="20">
                    <VerticalStackLayout Spacing="15">
                        <Label Text="Валюта"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="#4CAF50"/>

                        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="15" ColumnSpacing="15">
                            <Label Grid.Row="0" Grid.Column="0"
                                   Text="Стартовый баланс:"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="#666"
                                   VerticalOptions="Center"/>
                            <Border Grid.Row="0" Grid.Column="1"
                                    BackgroundColor="#F8F9FA"
                                    Stroke="#E0E0E0"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 8"
                                    Padding="0">
                                <Entry x:Name="StartBalanceEntry"
                                       Text="100"
                                       Keyboard="Numeric"
                                       BackgroundColor="Transparent"
                                       Margin="15,0"
                                       FontSize="14"
                                       HeightRequest="45"/>
                            </Border>

                            <Label Grid.Row="1" Grid.Column="0"
                                   Text="За урок:"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="#666"
                                   VerticalOptions="Center"/>
                            <Border Grid.Row="1" Grid.Column="1"
                                    BackgroundColor="#F8F9FA"
                                    Stroke="#E0E0E0"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 8"
                                    Padding="0">
                                <Entry x:Name="LessonRewardEntry"
                                       Text="50"
                                       Keyboard="Numeric"
                                       BackgroundColor="Transparent"
                                       Margin="15,0"
                                       FontSize="14"
                                       HeightRequest="45"/>
                            </Border>

                            <Label Grid.Row="2" Grid.Column="0"
                                   Text="За тест:"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="#666"
                                   VerticalOptions="Center"/>
                            <Border Grid.Row="2" Grid.Column="1"
                                    BackgroundColor="#F8F9FA"
                                    Stroke="#E0E0E0"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 8"
                                    Padding="0">
                                <Entry x:Name="TestRewardEntry"
                                       Text="75"
                                       Keyboard="Numeric"
                                       BackgroundColor="Transparent"
                                       Margin="15,0"
                                       FontSize="14"
                                       HeightRequest="45"/>
                            </Border>

                            <Label Grid.Row="3" Grid.Column="0"
                                   Text="Макс. в день:"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="#666"
                                   VerticalOptions="Center"/>
                            <Border Grid.Row="3" Grid.Column="1"
                                    BackgroundColor="#F8F9FA"
                                    Stroke="#E0E0E0"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 8"
                                    Padding="0">
                                <Entry x:Name="MaxDailyCurrencyEntry"
                                       Text="500"
                                       Keyboard="Numeric"
                                       BackgroundColor="Transparent"
                                       Margin="15,0"
                                       FontSize="14"
                                       HeightRequest="45"/>
                            </Border>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Безопасность -->
                <Border BackgroundColor="White"
                        Stroke="#F44336"
                        StrokeThickness="2"
                        StrokeShape="RoundRectangle 12"
                        Padding="20">
                    <VerticalStackLayout Spacing="15">
                        <Label Text="Безопасность"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="#F44336"/>

                        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="15" ColumnSpacing="15">
                            <Label Grid.Row="0" Grid.Column="0"
                                   Text="Мин. длина пароля:"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="#666"
                                   VerticalOptions="Center"/>
                            <Border Grid.Row="0" Grid.Column="1"
                                    BackgroundColor="#F8F9FA"
                                    Stroke="#E0E0E0"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 8"
                                    Padding="0">
                                <Entry x:Name="MinPasswordEntry"
                                       Text="6"
                                       Keyboard="Numeric"
                                       BackgroundColor="Transparent"
                                       Margin="15,0"
                                       FontSize="14"
                                       HeightRequest="45"/>
                            </Border>

                            <Label Grid.Row="1" Grid.Column="0"
                                   Text="Требовать 2FA:"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="#666"
                                   VerticalOptions="Center"/>
                            <Grid Grid.Row="1" Grid.Column="1">
                                <Switch x:Name="Require2FASwitch"
                                        IsToggled="False"
                                        OnColor="#F44336"
                                        ThumbColor="White"
                                        VerticalOptions="Center"/>
                            </Grid>

                            <Label Grid.Row="2" Grid.Column="0"
                                   Text="Сессия (часов):"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="#666"
                                   VerticalOptions="Center"/>
                            <Border Grid.Row="2" Grid.Column="1"
                                    BackgroundColor="#F8F9FA"
                                    Stroke="#E0E0E0"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 8"
                                    Padding="0">
                                <Entry x:Name="SessionTimeoutEntry"
                                       Text="24"
                                       Keyboard="Numeric"
                                       BackgroundColor="Transparent"
                                       Margin="15,0"
                                       FontSize="14"
                                       HeightRequest="45"/>
                            </Border>

                            <Label Grid.Row="3" Grid.Column="0"
                                   Text="Блокировка после:"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="#666"
                                   VerticalOptions="Center"/>
                            <Border Grid.Row="3" Grid.Column="1"
                                    BackgroundColor="#F8F9FA"
                                    Stroke="#E0E0E0"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 8"
                                    Padding="0">
                                <Entry x:Name="LockoutAttemptsEntry"
                                       Text="5"
                                       Keyboard="Numeric"
                                       BackgroundColor="Transparent"
                                       Margin="15,0"
                                       FontSize="14"
                                       HeightRequest="45"
                                       Placeholder="попыток"/>
                            </Border>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Уведомления -->
                <Border BackgroundColor="White"
                        Stroke="#2196F3"
                        StrokeThickness="2"
                        StrokeShape="RoundRectangle 12"
                        Padding="20">
                    <VerticalStackLayout Spacing="15">
                        <Label Text="Уведомления"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="#2196F3"/>

                        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto" RowSpacing="15" ColumnSpacing="15">
                            <Label Grid.Row="0" Grid.Column="0"
                                   Text="Email уведомления:"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="#666"
                                   VerticalOptions="Center"/>
                            <Grid Grid.Row="0" Grid.Column="1">
                                <Switch x:Name="EmailNotificationsSwitch"
                                        IsToggled="True"
                                        OnColor="#2196F3"
                                        ThumbColor="White"
                                        VerticalOptions="Center"/>
                            </Grid>

                            <Label Grid.Row="1" Grid.Column="0"
                                   Text="Push уведомления:"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="#666"
                                   VerticalOptions="Center"/>
                            <Grid Grid.Row="1" Grid.Column="1">
                                <Switch x:Name="PushNotificationsSwitch"
                                        IsToggled="True"
                                        OnColor="#2196F3"
                                        ThumbColor="White"
                                        VerticalOptions="Center"/>
                            </Grid>

                            <Label Grid.Row="2" Grid.Column="0"
                                   Text="SMS уведомления:"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="#666"
                                   VerticalOptions="Center"/>
                            <Grid Grid.Row="2" Grid.Column="1">
                                <Switch x:Name="SmsNotificationsSwitch"
                                        IsToggled="False"
                                        OnColor="#2196F3"
                                        ThumbColor="White"
                                        VerticalOptions="Center"/>
                            </Grid>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Очистка данных -->
                <Border BackgroundColor="White"
                        Stroke="#FF9800"
                        StrokeThickness="2"
                        StrokeShape="RoundRectangle 12"
                        Padding="20">
                    <VerticalStackLayout Spacing="15">
                        <Label Text="Очистка данных"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="#FF9800"/>

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                            <Button Grid.Column="0"
                                    Text="Очистить логи"
                                    Clicked="OnClearLogsClicked"
                                    BackgroundColor="#FF9800"
                                    TextColor="White"
                                    HeightRequest="45"
                                    CornerRadius="8"
                                    FontSize="13"/>
                            <Button Grid.Column="1"
                                    Text="Очистить кэш"
                                    Clicked="OnClearCacheClicked"
                                    BackgroundColor="#FF9800"
                                    TextColor="White"
                                    HeightRequest="45"
                                    CornerRadius="8"
                                    FontSize="13"/>
                        </Grid>

                        <Button Text="Сбросить все настройки"
                                Clicked="OnResetSettingsClicked"
                                BackgroundColor="#F44336"
                                TextColor="White"
                                HeightRequest="45"
                                CornerRadius="8"
                                FontSize="13"/>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>